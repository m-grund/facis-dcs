#################################################################
# Roles and lifecycle states
#################################################################

dcst:role-template-creator a dcs:Role ;
  dcs:identifier "TEMPLATE_CREATOR" ;
  rdfs:label "Template Creator"@en .

dcst:role-template-reviewer a dcs:Role ;
  dcs:identifier "TEMPLATE_REVIEWER" ;
  rdfs:label "Template Reviewer"@en .

dcst:role-template-approver a dcs:Role ;
  dcs:identifier "TEMPLATE_APPROVER" ;
  rdfs:label "Template Approver"@en .

dcst:role-contract-creator a dcs:Role ;
  dcs:identifier "CONTRACT_CREATOR" ;
  rdfs:label "Contract Creator"@en .

dcst:role-contract-reviewer a dcs:Role ;
  dcs:identifier "CONTRACT_REVIEWER" ;
  rdfs:label "Contract Reviewer"@en .

dcst:role-contract-approver a dcs:Role ;
  dcs:identifier "CONTRACT_APPROVER" ;
  rdfs:label "Contract Approver"@en .

dcst:role-auditor a dcs:Role ;
  dcs:identifier "AUDITOR" ;
  rdfs:label "Auditor"@en .

dcst:role-compliance-officer a dcs:Role ;
  dcs:identifier "COMPLIANCE_OFFICER" ;
  rdfs:label "Compliance Officer"@en .

dcst:state-draft a dcs:LifecycleState ;
  dcs:identifier "DRAFT" ;
  rdfs:label "Draft"@en .

dcst:state-submitted a dcs:LifecycleState ;
  dcs:identifier "SUBMITTED" ;
  rdfs:label "Submitted"@en .

dcst:state-reviewed a dcs:LifecycleState ;
  dcs:identifier "REVIEWED" ;
  rdfs:label "Reviewed"@en .

dcst:state-approved a dcs:LifecycleState ;
  dcs:identifier "APPROVED" ;
  rdfs:label "Approved"@en .

dcst:state-rejected a dcs:LifecycleState ;
  dcs:identifier "REJECTED" ;
  rdfs:label "Rejected"@en .

dcst:state-archived a dcs:LifecycleState ;
  dcs:identifier "ARCHIVED" ;
  rdfs:label "Archived"@en .

dcst:state-negotiation a dcs:LifecycleState ;
  dcs:identifier "NEGOTIATION" ;
  rdfs:label "Negotiation"@en .

dcst:state-signed a dcs:LifecycleState ;
  dcs:identifier "SIGNED" ;
  rdfs:label "Signed"@en .

