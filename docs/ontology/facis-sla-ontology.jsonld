  "@graph": [
    {
      "id": "https://w3id.org/facis/sla/ontology",
      "type": "owl:Ontology",
      "versionInfo": "1.0.0",
      "created": "2026-05-18",
      "modified": "2026-05-18",
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "partOf": "https://w3id.org/facis/dcs/ontology",
      "label": {
        "en": "FACIS SLA Ontology",
        "de": "FACIS SLA-Ontologie"
      },
      "comment": {
        "en": "JSON-LD ontology for service level agreements in FACIS DCS. It models SLA contracts, objectives, metrics, measurement, monitoring, breach handling, remedies, service credits, support windows, incidents, evidence, reporting, and canonical DCS domain-field mappings.",
        "de": "JSON-LD-Ontologie fuer Service Level Agreements in FACIS DCS. Sie modelliert SLA-Vertraege, Ziele, Metriken, Messung, Monitoring, Verletzungen, Abhilfen, Service Credits, Supportfenster, Incidents, Nachweise, Reporting und kanonische DCS-Domain-Field-Mappings."
      },
      "seeAlso": [
        "https://w3id.org/facis/dcs/ontology"
      ]
    },
    {
      "id": "sla:ServiceLevelAgreement",
      "type": "owl:Class",
      "subClassOf": "dcs:ServiceLevelAgreement",
      "label": {
        "en": "Service level agreement",
        "de": "Service Level Agreement"
      },
      "definition": {
        "en": "A contractual arrangement that defines measurable service obligations, measurement rules, monitoring evidence, consequences of non-compliance, and operational governance between a service provider and a customer.",
        "de": "Eine vertragliche Regelung, die messbare Servicepflichten, Messregeln, Monitoring-Nachweise, Folgen von Nichteinhaltung und operative Steuerung zwischen Dienstleister und Kunde festlegt."
      }
    },
    {
      "id": "sla:SLAClause",
      "type": "owl:Class",
      "subClassOf": "dcs:ClauseBlock",
      "label": {
        "en": "SLA clause",
        "de": "SLA-Klausel"
      },
      "definition": {
        "en": "A contract clause that states one or more service-level obligations, measurement terms, exclusions, escalation rules, or remedies."
      }
    },
    {
      "id": "sla:ServiceLevelObjective",
      "type": "owl:Class",
      "label": {
        "en": "Service level objective",
        "de": "Service-Level-Ziel"
      },
      "altLabel": {
        "en": "SLO"
      },
      "definition": {
        "en": "A measurable target that the provider is obliged to meet for a covered service within a defined measurement window."
      }
    },
    {
      "id": "sla:ServiceLevelIndicator",
      "type": "owl:Class",
      "label": {
        "en": "Service level indicator",
        "de": "Service-Level-Indikator"
      },
      "altLabel": {
        "en": "SLI"
      },
      "definition": {
        "en": "A measured value used to evaluate whether a service level objective has been met."
      }
    },
    {
      "id": "sla:SLAMetric",
      "type": "owl:Class",
      "label": {
        "en": "SLA metric",
        "de": "SLA-Metrik"
      },
      "definition": {
        "en": "The semantic definition of a quantity observed or calculated for SLA compliance, including unit, aggregation, formula, and data source."
      }
    },
    {
      "id": "sla:AvailabilityMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Availability metric",
        "de": "Verfuegbarkeitsmetrik"
      },
      "definition": {
        "en": "Metric expressing the proportion of time in which a service is available within the relevant measurement window."
      }
    },
    {
      "id": "sla:ResponseTimeMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Response time metric",
        "de": "Reaktionszeitmetrik"
      },
      "definition": {
        "en": "Metric measuring elapsed time until the provider acknowledges, triages, or otherwise responds to an incident, ticket, request, or alert."
      }
    },
    {
      "id": "sla:ResolutionTimeMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Resolution time metric",
        "de": "Loesungszeitmetrik"
      },
      "definition": {
        "en": "Metric measuring elapsed time until the provider restores the service, resolves an incident, delivers a workaround, or closes an agreed obligation."
      }
    },
    {
      "id": "sla:ThroughputMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Throughput metric",
        "de": "Durchsatzmetrik"
      }
    },
    {
      "id": "sla:LatencyMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Latency metric",
        "de": "Latenzmetrik"
      }
    },
    {
      "id": "sla:DataQualityMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Data quality metric",
        "de": "Datenqualitaetsmetrik"
      }
    },
    {
      "id": "sla:SecurityMetric",
      "type": "owl:Class",
      "subClassOf": "sla:SLAMetric",
      "label": {
        "en": "Security metric",
        "de": "Sicherheitsmetrik"
      }
    },
    {
      "id": "sla:Threshold",
      "type": "owl:Class",
      "label": {
        "en": "Threshold",
        "de": "Schwellwert"
      },
      "definition": {
        "en": "A value, comparison operator, and unit used to decide whether a metric satisfies an objective."
      }
    },
    {
      "id": "sla:MeasurementMethod",
      "type": "owl:Class",
      "label": {
        "en": "Measurement method",
        "de": "Messmethode"
      },
      "definition": {
        "en": "Rules for collecting, filtering, aggregating, and calculating SLA evidence."
      }
    },
    {
      "id": "sla:MeasurementWindow",
      "type": "owl:Class",
      "label": {
        "en": "Measurement window",
        "de": "Messzeitraum"
      },
      "definition": {
        "en": "The time interval over which SLA performance is calculated, for example monthly, quarterly, rolling 30 days, or per incident."
      }
    },
    {
      "id": "sla:SupportWindow",
      "type": "owl:Class",
      "label": {
        "en": "Support window",
        "de": "Supportfenster"
      },
      "definition": {
        "en": "The days, hours, time zone, and holiday rules during which support obligations are active."
      }
    },
    {
      "id": "sla:MonitoringSource",
      "type": "owl:Class",
      "label": {
        "en": "Monitoring source",
        "de": "Monitoring-Quelle"
      },
      "definition": {
        "en": "A trusted system or process that produces measurements used for SLA compliance assessment."
      }
    },
    {
      "id": "sla:MonitoringEvent",
      "type": "owl:Class",
      "label": {
        "en": "Monitoring event",
        "de": "Monitoring-Ereignis"
      },
      "definition": {
        "en": "A timestamped observation, alert, probe result, incident update, or audit-relevant event used in SLA assessment."
      }
    },
    {
      "id": "sla:Incident",
      "type": "owl:Class",
      "label": {
        "en": "Incident",
        "de": "Incident"
      },
      "definition": {
        "en": "An unplanned interruption, degradation, defect, security event, or service request that can trigger SLA obligations."
      }
    },
    {
      "id": "sla:IncidentSeverity",
      "type": "owl:Class",
      "label": {
        "en": "Incident severity",
        "de": "Incident-Schweregrad"
      },
      "definition": {
        "en": "A controlled classification of incident impact and urgency used to select response, resolution, escalation, and reporting obligations."
      }
    },
    {
      "id": "sla:SLABreach",
      "type": "owl:Class",
      "label": {
        "en": "SLA breach",
        "de": "SLA-Verletzung"
      },
      "definition": {
        "en": "A determination that one or more measured values failed the applicable threshold after exclusions and measurement rules have been applied."
      }
    },
    {
      "id": "sla:BreachAssessment",
      "type": "owl:Class",
      "label": {
        "en": "Breach assessment",
        "de": "Verletzungsbewertung"
      },
      "definition": {
        "en": "The compliance evaluation record that links objectives, measurements, exclusions, evidence, and breach decisions."
      }
    },
    {
      "id": "sla:Remedy",
      "type": "owl:Class",
      "label": {
        "en": "Remedy",
        "de": "Abhilfe"
      },
      "definition": {
        "en": "A contractual consequence or corrective obligation triggered by an SLA breach."
      }
    },
    {
      "id": "sla:ServiceCredit",
      "type": "owl:Class",
      "subClassOf": "sla:Remedy",
      "label": {
        "en": "Service credit",
        "de": "Service Credit"
      },
      "definition": {
        "en": "A monetary or percentage credit granted to the customer when agreed SLA conditions are not met."
      }
    },
    {
      "id": "sla:TerminationRight",
      "type": "owl:Class",
      "subClassOf": "sla:Remedy",
      "label": {
        "en": "Termination right",
        "de": "Kuendigungsrecht"
      }
    },
    {
      "id": "sla:CorrectiveActionPlan",
      "type": "owl:Class",
      "subClassOf": "sla:Remedy",
      "label": {
        "en": "Corrective action plan",
        "de": "Massnahmenplan"
      }
    },
    {
      "id": "sla:EscalationPolicy",
      "type": "owl:Class",
      "label": {
        "en": "Escalation policy",
        "de": "Eskalationsregel"
      },
      "definition": {
        "en": "Rules that define escalation levels, recipients, deadlines, and required actions when service levels are at risk or breached."
      }
    },
    {
      "id": "sla:EscalationStep",
      "type": "owl:Class",
      "label": {
        "en": "Escalation step",
        "de": "Eskalationsstufe"
      }
    },
    {
      "id": "sla:SLAExclusion",
      "type": "owl:Class",
      "label": {
        "en": "SLA exclusion",
        "de": "SLA-Ausnahme"
      },
      "definition": {
        "en": "A condition, event, period, or responsibility that is excluded from SLA calculations."
      }
    },
    {
      "id": "sla:MaintenanceWindow",
      "type": "owl:Class",
      "subClassOf": "sla:SLAExclusion",
      "label": {
        "en": "Maintenance window",
        "de": "Wartungsfenster"
      }
    },
    {
      "id": "sla:ForceMajeureExclusion",
      "type": "owl:Class",
      "subClassOf": "sla:SLAExclusion",
      "label": {
        "en": "Force majeure exclusion",
        "de": "Hoehere-Gewalt-Ausnahme"
      }
    },
    {
      "id": "sla:CustomerCausedExclusion",
      "type": "owl:Class",
      "subClassOf": "sla:SLAExclusion",
      "label": {
        "en": "Customer-caused exclusion",
        "de": "Kundenseitig verursachte Ausnahme"
      }
    },
    {
      "id": "sla:SLAReport",
      "type": "owl:Class",
      "label": {
        "en": "SLA report",
        "de": "SLA-Bericht"
      },
      "definition": {
        "en": "A periodic or event-driven report containing SLA performance, breach status, evidence references, service credits, and open corrective actions."
      }
    },
    {
      "id": "sla:AuditEvidence",
      "type": "owl:Class",
      "label": {
        "en": "Audit evidence",
        "de": "Audit-Nachweis"
      },
      "definition": {
        "en": "Evidence that supports an SLA measurement, breach decision, remedy, or dispute resolution process."
      }
    },
    {
      "id": "sla:MetricUnit",
      "type": "owl:Class",
      "label": {
        "en": "Metric unit",
        "de": "Metrikeinheit"
      }
    },
    {
      "id": "sla:ComparisonOperator",
      "type": "owl:Class",
      "label": {
        "en": "Comparison operator",
        "de": "Vergleichsoperator"
      }
    },
    {
      "id": "sla:hasParty",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "dcs:Party",
      "label": {
        "en": "has party",
        "de": "hat Partei"
      }
    },
    {
      "id": "sla:hasProvider",
      "type": "owl:ObjectProperty",
      "subPropertyOf": "sla:hasParty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "dcs:Party",
      "label": {
        "en": "has provider",
        "de": "hat Anbieter"
      }
    },
    {
      "id": "sla:hasCustomer",
      "type": "owl:ObjectProperty",
      "subPropertyOf": "sla:hasParty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "dcs:Party",
      "label": {
        "en": "has customer",
        "de": "hat Kunde"
      }
    },
    {
      "id": "sla:coversService",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "dcs:Service",
      "label": {
        "en": "covers service",
        "de": "deckt Service ab"
      }
    },
    {
      "id": "sla:hasServiceLevelObjective",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:ServiceLevelObjective",
      "label": {
        "en": "has service level objective",
        "de": "hat Service-Level-Ziel"
      }
    },
    {
      "id": "sla:hasMetric",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelObjective",
      "range": "sla:SLAMetric",
      "label": {
        "en": "has metric",
        "de": "hat Metrik"
      }
    },
    {
      "id": "sla:hasThreshold",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelObjective",
      "range": "sla:Threshold",
      "label": {
        "en": "has threshold",
        "de": "hat Schwellwert"
      }
    },
    {
      "id": "sla:hasMeasurementMethod",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelObjective",
      "range": "sla:MeasurementMethod",
      "label": {
        "en": "has measurement method",
        "de": "hat Messmethode"
      }
    },
    {
      "id": "sla:hasMeasurementWindow",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelObjective",
      "range": "sla:MeasurementWindow",
      "label": {
        "en": "has measurement window",
        "de": "hat Messzeitraum"
      }
    },
    {
      "id": "sla:hasMonitoringSource",
      "type": "owl:ObjectProperty",
      "domain": "sla:MeasurementMethod",
      "range": "sla:MonitoringSource",
      "label": {
        "en": "has monitoring source",
        "de": "hat Monitoring-Quelle"
      }
    },
    {
      "id": "sla:hasBreach",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:SLABreach",
      "label": {
        "en": "has breach",
        "de": "hat Verletzung"
      }
    },
    {
      "id": "sla:hasRemedy",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:Remedy",
      "label": {
        "en": "has remedy",
        "de": "hat Abhilfe"
      }
    },
    {
      "id": "sla:hasServiceCredit",
      "type": "owl:ObjectProperty",
      "subPropertyOf": "sla:hasRemedy",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:ServiceCredit",
      "label": {
        "en": "has service credit",
        "de": "hat Service Credit"
      }
    },
    {
      "id": "sla:hasEscalationPolicy",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:EscalationPolicy",
      "label": {
        "en": "has escalation policy",
        "de": "hat Eskalationsregel"
      }
    },
    {
      "id": "sla:hasIncidentSeverity",
      "type": "owl:ObjectProperty",
      "domain": "sla:Incident",
      "range": "sla:IncidentSeverity",
      "label": {
        "en": "has incident severity",
        "de": "hat Incident-Schweregrad"
      }
    },
    {
      "id": "sla:hasSupportWindow",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:SupportWindow",
      "label": {
        "en": "has support window",
        "de": "hat Supportfenster"
      }
    },
    {
      "id": "sla:hasExclusion",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:SLAExclusion",
      "label": {
        "en": "has exclusion",
        "de": "hat Ausnahme"
      }
    },
    {
      "id": "sla:hasReport",
      "type": "owl:ObjectProperty",
      "domain": "sla:ServiceLevelAgreement",
      "range": "sla:SLAReport",
      "label": {
        "en": "has report",
        "de": "hat Bericht"
      }
    },
    {
      "id": "sla:hasAuditEvidence",
      "type": "owl:ObjectProperty",
      "range": "sla:AuditEvidence",
      "label": {
        "en": "has audit evidence",
        "de": "hat Audit-Nachweis"
      }
    },
    {
      "id": "sla:hasUnit",
      "type": "owl:ObjectProperty",
      "domain": "sla:SLAMetric",
      "range": "sla:MetricUnit",
      "label": {
        "en": "has unit",
        "de": "hat Einheit"
      }
    },
    {
      "id": "sla:hasOperator",
      "type": "owl:ObjectProperty",
      "domain": "sla:Threshold",
      "range": "sla:ComparisonOperator",
      "label": {
        "en": "has operator",
        "de": "hat Operator"
      }
    },
    {
      "id": "sla:hasTargetValue",
      "type": "owl:DatatypeProperty",
      "domain": "sla:Threshold",
      "label": {
        "en": "has target value",
        "de": "hat Zielwert"
      }
    },
    {
      "id": "sla:hasActualValue",
      "type": "owl:DatatypeProperty",
      "domain": "sla:ServiceLevelIndicator",
      "label": {
        "en": "has actual value",
        "de": "hat Istwert"
      }
    },
    {
      "id": "sla:hasDuration",
      "type": "owl:DatatypeProperty",
      "range": "xsd:duration",
      "label": {
        "en": "has duration",
        "de": "hat Dauer"
      }
    },
    {
      "id": "sla:hasCalculationFormula",
      "type": "owl:DatatypeProperty",
      "range": "xsd:string",
      "label": {
        "en": "has calculation formula",
        "de": "hat Berechnungsformel"
      }
    },
    {
      "id": "sla:hasReviewFrequency",
      "type": "owl:DatatypeProperty",
      "range": "xsd:string",
      "label": {
        "en": "has review frequency",
        "de": "hat Prueffrequenz"
      }
    },
    {
      "id": "sla:hasCurrency",
      "type": "owl:DatatypeProperty",
      "range": "xsd:string",
      "label": {
        "en": "has currency",
        "de": "hat Waehrung"
      }
    },
    {
      "id": "sla:isCumulative",
      "type": "owl:DatatypeProperty",
      "range": "xsd:boolean",
      "label": {
        "en": "is cumulative",
        "de": "ist kumulativ"
      }
    },
    {
      "id": "sla:isCustomerReportable",
      "type": "owl:DatatypeProperty",
      "range": "xsd:boolean",
      "label": {
        "en": "is customer reportable",
        "de": "ist kundenberichtspflichtig"
      }
    },
    {
      "id": "slat:operator-greater-than-or-equal",
      "type": "sla:ComparisonOperator",
      "prefLabel": {
        "en": "greater than or equal",
        "de": "groesser gleich"
      },
      "schema:value": ">="
    },
    {
      "id": "slat:operator-less-than-or-equal",
      "type": "sla:ComparisonOperator",
      "prefLabel": {
        "en": "less than or equal",
        "de": "kleiner gleich"
      },
      "schema:value": "<="
    },
    {
      "id": "slat:operator-equal",
      "type": "sla:ComparisonOperator",
      "prefLabel": {
        "en": "equal",
        "de": "gleich"
      },
      "schema:value": "="
    },
    {
      "id": "slat:unit-percent",
      "type": "sla:MetricUnit",
      "prefLabel": {
        "en": "percent",
        "de": "Prozent"
      },
      "schema:unitCode": "P1"
    },
    {
      "id": "slat:unit-minute",
      "type": "sla:MetricUnit",
      "prefLabel": {
        "en": "minute",
        "de": "Minute"
      },
      "schema:unitCode": "MIN"
    },
    {
      "id": "slat:unit-hour",
      "type": "sla:MetricUnit",
      "prefLabel": {
        "en": "hour",
        "de": "Stunde"
      },
      "schema:unitCode": "HUR"
    },
    {
      "id": "slat:unit-millisecond",
      "type": "sla:MetricUnit",
      "prefLabel": {
        "en": "millisecond",
        "de": "Millisekunde"
      }
    },
    {
      "id": "slat:unit-incident",
      "type": "sla:MetricUnit",
      "prefLabel": {
        "en": "incident",
        "de": "Incident"
      }
    },
    {
      "id": "slat:metric-availability-percent",
      "type": "sla:AvailabilityMetric",
      "prefLabel": {
        "en": "availability percentage",
        "de": "Verfuegbarkeit in Prozent"
      },
      "hasUnit": "slat:unit-percent",
      "hasCalculationFormula": "((measurementWindowDuration - excludedDowntime - countedDowntime) / (measurementWindowDuration - excludedDowntime)) * 100"
    },
    {
      "id": "slat:metric-response-time-minutes",
      "type": "sla:ResponseTimeMetric",
      "prefLabel": {
        "en": "response time in minutes",
        "de": "Reaktionszeit in Minuten"
      },
      "hasUnit": "slat:unit-minute",
      "hasCalculationFormula": "firstProviderResponseTimestamp - incidentOpenTimestamp"
    },
    {
      "id": "slat:metric-resolution-time-minutes",
      "type": "sla:ResolutionTimeMetric",
      "prefLabel": {
        "en": "resolution time in minutes",
        "de": "Loesungszeit in Minuten"
      },
      "hasUnit": "slat:unit-minute",
      "hasCalculationFormula": "resolutionTimestamp - incidentOpenTimestamp"
    },
    {
      "id": "slat:metric-latency-p95-ms",
      "type": "sla:LatencyMetric",
      "prefLabel": {
        "en": "p95 latency in milliseconds",
        "de": "p95-Latenz in Millisekunden"
      },
      "hasUnit": "slat:unit-millisecond",
      "hasCalculationFormula": "percentile(requestLatencyMilliseconds, 95)"
    },
    {
      "id": "slat:window-calendar-month",
      "type": "sla:MeasurementWindow",
      "prefLabel": {
        "en": "calendar month",
        "de": "Kalendermonat"
      },
      "hasDuration": "P1M"
    },
    {
      "id": "slat:window-calendar-quarter",
      "type": "sla:MeasurementWindow",
      "prefLabel": {
        "en": "calendar quarter",
        "de": "Kalenderquartal"
      },
      "hasDuration": "P3M"
    },
    {
      "id": "slat:window-rolling-30-days",
      "type": "sla:MeasurementWindow",
      "prefLabel": {
        "en": "rolling 30 days",
        "de": "rollierende 30 Tage"
      },
      "hasDuration": "P30D"
    },
    {
      "id": "slat:window-per-incident",
      "type": "sla:MeasurementWindow",
      "prefLabel": {
        "en": "per incident",
        "de": "pro Incident"
      }
    },
    {
      "id": "slat:support-24x7",
      "type": "sla:SupportWindow",
      "prefLabel": {
        "en": "24x7 support",
        "de": "24x7-Support"
      },
      "hasBusinessDay": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "hasStartTime": "00:00:00",
      "hasEndTime": "23:59:59",
      "hasTimeZone": "UTC"
    },
    {
      "id": "slat:support-business-hours-europe-berlin",
      "type": "sla:SupportWindow",
      "prefLabel": {
        "en": "business-hours support Europe/Berlin",
        "de": "Support zu Geschaeftszeiten Europe/Berlin"
      },
      "hasBusinessDay": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "hasStartTime": "09:00:00",
      "hasEndTime": "17:00:00",
      "hasTimeZone": "Europe/Berlin"
    },
    {
      "id": "slat:severity-critical",
      "type": "sla:IncidentSeverity",
      "prefLabel": {
        "en": "critical",
        "de": "kritisch"
      },
      "hasPriority": 1,
      "definition": {
        "en": "Complete outage, severe security impact, or business-critical service unavailable for all or a material group of users."
      }
    },
    {
      "id": "slat:severity-high",
      "type": "sla:IncidentSeverity",
      "prefLabel": {
        "en": "high",
        "de": "hoch"
      },
      "hasPriority": 2,
      "definition": {
        "en": "Major degradation or partial outage with significant operational impact."
      }
    },
    {
      "id": "slat:severity-medium",
      "type": "sla:IncidentSeverity",
      "prefLabel": {
        "en": "medium",
        "de": "mittel"
      },
      "hasPriority": 3,
      "definition": {
        "en": "Limited degradation, workaround available, or non-critical operational impact."
      }
    },
    {
      "id": "slat:severity-low",
      "type": "sla:IncidentSeverity",
      "prefLabel": {
        "en": "low",
        "de": "niedrig"
      },
      "hasPriority": 4,
      "definition": {
        "en": "Minor issue, information request, or cosmetic defect without material operational impact."
      }
    },
    {
      "id": "slat:method-provider-monitoring",
      "type": "sla:MeasurementMethod",
      "prefLabel": {
        "en": "provider monitoring",
        "de": "Provider-Monitoring"
      },
      "definition": {
        "en": "Measurements are derived from provider-operated monitoring systems and retained as audit evidence."
      }
    },
    {
      "id": "slat:method-customer-monitoring",
      "type": "sla:MeasurementMethod",
      "prefLabel": {
        "en": "customer monitoring",
        "de": "Kunden-Monitoring"
      },
      "definition": {
        "en": "Measurements are derived from customer-operated monitoring systems, subject to agreed data quality and dispute rules."
      }
    },
    {
      "id": "slat:method-third-party-monitoring",
      "type": "sla:MeasurementMethod",
      "prefLabel": {
        "en": "third-party monitoring",
        "de": "Drittanbieter-Monitoring"
      },
      "definition": {
        "en": "Measurements are derived from an independent monitoring or audit provider."
      }
    },
    {
      "id": "slat:remedy-service-credit",
      "type": "sla:ServiceCredit",
      "prefLabel": {
        "en": "service credit",
        "de": "Service Credit"
      },
      "hasCurrency": "EUR",
      "isCumulative": false,
      "definition": {
        "en": "Credit against recurring service fees, calculated according to the applicable breach tier and capped by the agreed maximum."
      }
    },
    {
      "id": "slat:remedy-corrective-action-plan",
      "type": "sla:CorrectiveActionPlan",
      "prefLabel": {
        "en": "corrective action plan",
        "de": "Massnahmenplan"
      },
      "definition": {
        "en": "Provider must document root cause, corrective actions, owner, due date, and prevention measures after a material breach."
      }
    },
    {
      "id": "slat:remedy-termination-for-chronic-breach",
      "type": "sla:TerminationRight",
      "prefLabel": {
        "en": "termination for chronic breach",
        "de": "Kuendigung bei wiederholter Verletzung"
      },
      "definition": {
        "en": "Customer may terminate if the same material SLA is breached repeatedly within the agreed look-back period."
      }
    },
    {
      "id": "slat:exclusion-planned-maintenance",
      "type": "sla:MaintenanceWindow",
      "prefLabel": {
        "en": "planned maintenance",
        "de": "geplante Wartung"
      },
      "definition": {
        "en": "Pre-announced maintenance windows are excluded from availability calculations if notification and duration rules are met."
      }
    },
    {
      "id": "slat:exclusion-force-majeure",
      "type": "sla:ForceMajeureExclusion",
      "prefLabel": {
        "en": "force majeure",
        "de": "hoehere Gewalt"
      }
    },
    {
      "id": "slat:exclusion-customer-action",
      "type": "sla:CustomerCausedExclusion",
      "prefLabel": {
        "en": "customer-caused issue",
        "de": "kundenseitig verursachtes Problem"
      }
    },
    {
      "id": "slat:constraint-availability-percent",
      "type": "dcs:ValueConstraint",
      "minInclusive": 0,
      "maxInclusive": 100,
      "format": "percentage",
      "label": {
        "en": "SLA availability percentage constraint",
        "de": "SLA-Verfuegbarkeitsprozent-Constraint"
      }
    },
    {
      "id": "slat:constraint-duration-minutes-non-negative",
      "type": "dcs:ValueConstraint",
      "minInclusive": 0,
      "format": "duration-minutes",
      "label": {
        "en": "Non-negative duration in minutes constraint",
        "de": "Nichtnegative Dauer in Minuten Constraint"
      }
    },
    {
      "id": "slat:field-service-sla-availability",
      "type": "dcs:DomainField",
      "semanticPath": "service.sla.availability",
      "schemaRef": "facis.dcs.service.v1",
      "parameterType": "decimal",
      "hasValueConstraint": "slat:constraint-availability-percent",
      "label": {
        "en": "SLA availability",
        "de": "SLA-Verfuegbarkeit"
      }
    },
    {
      "id": "slat:field-service-sla-responseTime",
      "type": "dcs:DomainField",
      "semanticPath": "service.sla.responseTime",
      "schemaRef": "facis.dcs.service.v1",
      "parameterType": "integer",
      "hasValueConstraint": "slat:constraint-duration-minutes-non-negative",
      "label": {
        "en": "SLA response time",
        "de": "SLA-Reaktionszeit"
      }
    },
    {
      "id": "slat:field-service-sla-resolutionTime",
      "type": "dcs:DomainField",
      "semanticPath": "service.sla.resolutionTime",
      "schemaRef": "facis.dcs.service.v1",
      "parameterType": "integer",
      "hasValueConstraint": "slat:constraint-duration-minutes-non-negative",
      "label": {
        "en": "SLA resolution time",
        "de": "SLA-Loesungszeit"
      }
    },
    {
      "id": "slat:field-service-sla-supportHours",
      "type": "dcs:DomainField",
      "semanticPath": "service.sla.supportHours",
      "schemaRef": "facis.dcs.service.v1",
      "parameterType": "string",
      "label": {
        "en": "SLA support hours",
        "de": "SLA-Supportzeiten"
      }
    },
    {
      "id": "slat:block-sla-availability",
      "type": "dcs:BlockCatalogueEntry",
      "blockCatalogueId": "facis.block.sla.availability",
      "schemaRef": "facis.dcs.service.v1",
      "semanticPath": "service.sla.availability",
      "label": {
        "en": "SLA availability block",
        "de": "SLA-Verfuegbarkeitsblock"
      }
    },
    {
      "id": "slat:block-sla-response-time",
      "type": "dcs:BlockCatalogueEntry",
      "blockCatalogueId": "facis.block.sla.response-time",
      "schemaRef": "facis.dcs.service.v1",
      "semanticPath": "service.sla.responseTime",
      "label": {
        "en": "SLA response-time block",
        "de": "SLA-Reaktionszeitblock"
      }
    },
    {
      "id": "slat:block-sla-resolution-time",
      "type": "dcs:BlockCatalogueEntry",
      "blockCatalogueId": "facis.block.sla.resolution-time",
      "schemaRef": "facis.dcs.service.v1",
      "semanticPath": "service.sla.resolutionTime",
      "label": {
        "en": "SLA resolution-time block",
        "de": "SLA-Loesungszeitblock"
      }
    },
    {
      "id": "slat:block-sla-support",
      "type": "dcs:BlockCatalogueEntry",
      "blockCatalogueId": "facis.block.sla.support",
      "schemaRef": "facis.dcs.service.v1",
      "semanticPath": "service.sla.supportHours",
      "label": {
        "en": "SLA support block",
        "de": "SLA-Supportblock"
      }
    },
    {
      "id": "slat:slo-availability-99-9-monthly",
      "type": "sla:ServiceLevelObjective",
      "prefLabel": {
        "en": "99.9 percent monthly availability",
        "de": "99,9 Prozent monatliche Verfuegbarkeit"
      },
      "hasMetric": "slat:metric-availability-percent",
      "hasMeasurementWindow": "slat:window-calendar-month",
      "hasMeasurementMethod": "slat:method-provider-monitoring",
      "hasThreshold": {
        "id": "slat:threshold-availability-99-9",
        "type": "sla:Threshold",
        "hasOperator": "slat:operator-greater-than-or-equal",
        "hasTargetValue": 99.9,
        "hasUnit": "slat:unit-percent"
      },
      "isCustomerReportable": true
    },
    {
      "id": "slat:slo-critical-response-15-minutes",
      "type": "sla:ServiceLevelObjective",
      "prefLabel": {
        "en": "critical incident response within 15 minutes",
        "de": "Reaktion auf kritischen Incident innerhalb von 15 Minuten"
      },
      "hasMetric": "slat:metric-response-time-minutes",
      "hasMeasurementWindow": "slat:window-per-incident",
      "hasMeasurementMethod": "slat:method-provider-monitoring",
      "hasIncidentSeverity": "slat:severity-critical",
      "hasThreshold": {
        "id": "slat:threshold-response-critical-15",
        "type": "sla:Threshold",
        "hasOperator": "slat:operator-less-than-or-equal",
        "hasTargetValue": 15,
        "hasUnit": "slat:unit-minute"
      },
      "isCustomerReportable": true
    },
    {
      "id": "slat:slo-critical-resolution-240-minutes",
      "type": "sla:ServiceLevelObjective",
      "prefLabel": {
        "en": "critical incident resolution within 240 minutes",
        "de": "Loesung eines kritischen Incident innerhalb von 240 Minuten"
      },
      "hasMetric": "slat:metric-resolution-time-minutes",
      "hasMeasurementWindow": "slat:window-per-incident",
      "hasMeasurementMethod": "slat:method-provider-monitoring",
      "hasIncidentSeverity": "slat:severity-critical",
      "hasThreshold": {
        "id": "slat:threshold-resolution-critical-240",
        "type": "sla:Threshold",
        "hasOperator": "slat:operator-less-than-or-equal",
        "hasTargetValue": 240,
        "hasUnit": "slat:unit-minute"
      },
      "isCustomerReportable": true
    },
    {
      "id": "slat:example-standard-cloud-service-sla",
      "type": "sla:ServiceLevelAgreement",
      "prefLabel": {
        "en": "Example standard cloud service SLA",
        "de": "Beispiel Standard Cloud Service SLA"
      },
      "coversService": "dcs:Service",
      "hasServiceLevelObjective": [
        "slat:slo-availability-99-9-monthly",
        "slat:slo-critical-response-15-minutes",
        "slat:slo-critical-resolution-240-minutes"
      ],
      "hasSupportWindow": "slat:support-24x7",
      "hasExclusion": [
        "slat:exclusion-planned-maintenance",
        "slat:exclusion-force-majeure",
        "slat:exclusion-customer-action"
      ],
      "hasRemedy": [
        "slat:remedy-service-credit",
        "slat:remedy-corrective-action-plan",
        "slat:remedy-termination-for-chronic-breach"
      ],
      "hasReviewFrequency": "monthly"
    }
  ]
}
