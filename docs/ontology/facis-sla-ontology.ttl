  rdfs:label "Location"@en .

dcs:street a rdf:Property ;
  rdfs:label "Street"@en ;
  rdfs:range xsd:string .

dcs:postalCode a rdf:Property ;
  rdfs:label "Postal Code"@en ;
  rdfs:range xsd:string .

dcs:city a rdf:Property ;
  rdfs:label "City"@en ;
  rdfs:range xsd:string .

dcs:region a rdf:Property ;
  rdfs:label "Region"@en ;
  rdfs:range xsd:string .

dcs:country a rdf:Property ;
  rdfs:label "Country"@en ;
  rdfs:range xsd:string .

dcs:hasSignatory a rdf:Property ;
  rdfs:label "Has Signatory"@en ;
  rdfs:range dcs:Signatory .

dcs:hasCredentialReference a rdf:Property ;
  rdfs:label "Has Credential Reference"@en ;
  rdfs:range dcs:CredentialReference .

dcs:credentialId a rdf:Property ;
  rdfs:label "Credential ID"@en ;
  rdfs:range xsd:string .

dcs:credentialType a rdf:Property ;
  rdfs:label "Credential Type"@en ;
  rdfs:range xsd:string .

dcs:statusListRef a rdf:Property ;
  rdfs:label "Status List Reference"@en ;
  rdfs:range xsd:anyURI .

dcs:targetSystem a rdf:Property ;
  rdfs:label "Target System"@en ;
  rdfs:range xsd:string .

dcs:targetEndpoint a rdf:Property ;
  rdfs:label "Target Endpoint"@en ;
  rdfs:range xsd:anyURI .

dcs:hasPolicyBundle a rdf:Property ;
  rdfs:label "Has Policy Bundle"@en ;
  rdfs:range dcs:PolicyBundle .

