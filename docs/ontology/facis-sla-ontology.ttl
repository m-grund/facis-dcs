@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix sla: <https://w3id.org/facis/sla/ontology#> .
@prefix slat: <https://w3id.org/facis/sla/taxonomy#> .
@prefix dcst: <https://w3id.org/facis/dcs/taxonomy/v1#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/facis/sla/ontology> a owl:Ontology ;
  owl:versionInfo "1.1.0" ;
  dcterms:created "2026-05-18" ;
  dcterms:modified "2026-05-29" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:isPartOf <https://w3id.org/facis/dcs/ontology/v1> ;
  rdfs:label "FACIS SLA Ontology"@en, "FACIS SLA-Ontologie"@de ;
  rdfs:comment "Turtle ontology for service level agreements in FACIS DCS. It models SLA contracts, objectives, metrics, measurement, monitoring, breach handling, remedies, service credits, support windows, incidents, evidence, reporting, and canonical DCS domain-field mappings."@en, "Turtle-Ontologie fuer Service Level Agreements in FACIS DCS. Sie modelliert SLA-Vertraege, Ziele, Metriken, Messung, Monitoring, Verletzungen, Abhilfen, Service Credits, Supportfenster, Incidents, Nachweise, Reporting und kanonische DCS-Domain-Field-Mappings."@de ;
  rdfs:seeAlso <https://w3id.org/facis/dcs/ontology>, <https://w3id.org/facis/dcs/ontology/v1> .

sla:ServiceLevelAgreement a owl:Class ;
  rdfs:subClassOf dcs:ServiceLevelAgreement ;
  rdfs:label "Service level agreement"@en, "Service Level Agreement"@de ;
  skos:definition "A contractual arrangement that defines measurable service obligations, measurement rules, monitoring evidence, consequences of non-compliance, and operational governance between a service provider and a customer."@en, "Eine vertragliche Regelung, die messbare Servicepflichten, Messregeln, Monitoring-Nachweise, Folgen von Nichteinhaltung und operative Steuerung zwischen Dienstleister und Kunde festlegt."@de .

sla:SLAClause a owl:Class ;
  rdfs:subClassOf dcs:ClauseBlock ;
  rdfs:label "SLA clause"@en, "SLA-Klausel"@de ;
  skos:definition "A contract clause that states one or more service-level obligations, measurement terms, exclusions, escalation rules, or remedies."@en .

sla:ServiceLevelObjective a owl:Class ;
  rdfs:label "Service level objective"@en, "Service-Level-Ziel"@de ;
  skos:altLabel "SLO"@en ;
  skos:definition "A measurable target that the provider is obliged to meet for a covered service within a defined measurement window."@en .

sla:ServiceLevelIndicator a owl:Class ;
  rdfs:label "Service level indicator"@en, "Service-Level-Indikator"@de ;
  skos:altLabel "SLI"@en ;
  skos:definition "A measured value used to evaluate whether a service level objective has been met."@en .

sla:SLAMetric a owl:Class ;
  rdfs:label "SLA metric"@en, "SLA-Metrik"@de ;
  skos:definition "The semantic definition of a quantity observed or calculated for SLA compliance, including unit, aggregation, formula, and data source."@en .

sla:AvailabilityMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Availability metric"@en, "Verfuegbarkeitsmetrik"@de ;
  skos:definition "Metric expressing the proportion of time in which a service is available within the relevant measurement window."@en .

sla:ResponseTimeMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Response time metric"@en, "Reaktionszeitmetrik"@de ;
  skos:definition "Metric measuring elapsed time until the provider acknowledges, triages, or otherwise responds to an incident, ticket, request, or alert."@en .

sla:ResolutionTimeMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Resolution time metric"@en, "Loesungszeitmetrik"@de ;
  skos:definition "Metric measuring elapsed time until the provider restores the service, resolves an incident, delivers a workaround, or closes an agreed obligation."@en .

sla:ThroughputMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Throughput metric"@en, "Durchsatzmetrik"@de .

sla:LatencyMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Latency metric"@en, "Latenzmetrik"@de .

sla:DataQualityMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Data quality metric"@en, "Datenqualitaetsmetrik"@de .

sla:SecurityMetric a owl:Class ;
  rdfs:subClassOf sla:SLAMetric ;
  rdfs:label "Security metric"@en, "Sicherheitsmetrik"@de .

sla:Threshold a owl:Class ;
  rdfs:label "Threshold"@en, "Schwellwert"@de ;
  skos:definition "A value, comparison operator, and unit used to decide whether a metric satisfies an objective."@en .

sla:MeasurementMethod a owl:Class ;
  rdfs:label "Measurement method"@en, "Messmethode"@de ;
  skos:definition "Rules for collecting, filtering, aggregating, and calculating SLA evidence."@en .

sla:MeasurementWindow a owl:Class ;
  rdfs:label "Measurement window"@en, "Messzeitraum"@de ;
  skos:definition "The time interval over which SLA performance is calculated, for example monthly, quarterly, rolling 30 days, or per incident."@en .

sla:SupportWindow a owl:Class ;
  rdfs:label "Support window"@en, "Supportfenster"@de ;
  skos:definition "The days, hours, time zone, and holiday rules during which support obligations are active."@en .

sla:MonitoringSource a owl:Class ;
  rdfs:label "Monitoring source"@en, "Monitoring-Quelle"@de ;
  skos:definition "A trusted system or process that produces measurements used for SLA compliance assessment."@en .

sla:MonitoringEvent a owl:Class ;
  rdfs:label "Monitoring event"@en, "Monitoring-Ereignis"@de ;
  skos:definition "A timestamped observation, alert, probe result, incident update, or audit-relevant event used in SLA assessment."@en .

sla:Incident a owl:Class ;
  rdfs:label "Incident"@en, "Incident"@de ;
  skos:definition "An unplanned interruption, degradation, defect, security event, or service request that can trigger SLA obligations."@en .

sla:IncidentSeverity a owl:Class ;
  rdfs:label "Incident severity"@en, "Incident-Schweregrad"@de ;
  skos:definition "A controlled classification of incident impact and urgency used to select response, resolution, escalation, and reporting obligations."@en .

sla:SLABreach a owl:Class ;
  rdfs:label "SLA breach"@en, "SLA-Verletzung"@de ;
  skos:definition "A determination that one or more measured values failed the applicable threshold after exclusions and measurement rules have been applied."@en .

sla:BreachAssessment a owl:Class ;
  rdfs:label "Breach assessment"@en, "Verletzungsbewertung"@de ;
  skos:definition "The compliance evaluation record that links objectives, measurements, exclusions, evidence, and breach decisions."@en .

sla:Remedy a owl:Class ;
  rdfs:label "Remedy"@en, "Abhilfe"@de ;
  skos:definition "A contractual consequence or corrective obligation triggered by an SLA breach."@en .

sla:ServiceCredit a owl:Class ;
  rdfs:subClassOf sla:Remedy ;
  rdfs:label "Service credit"@en, "Service Credit"@de ;
  skos:definition "A monetary or percentage credit granted to the customer when agreed SLA conditions are not met."@en .

sla:TerminationRight a owl:Class ;
  rdfs:subClassOf sla:Remedy ;
  rdfs:label "Termination right"@en, "Kuendigungsrecht"@de .

sla:CorrectiveActionPlan a owl:Class ;
  rdfs:subClassOf sla:Remedy ;
  rdfs:label "Corrective action plan"@en, "Massnahmenplan"@de .

sla:EscalationPolicy a owl:Class ;
  rdfs:label "Escalation policy"@en, "Eskalationsregel"@de ;
  skos:definition "Rules that define escalation levels, recipients, deadlines, and required actions when service levels are at risk or breached."@en .

sla:EscalationStep a owl:Class ;
  rdfs:label "Escalation step"@en, "Eskalationsstufe"@de .

sla:SLAExclusion a owl:Class ;
  rdfs:label "SLA exclusion"@en, "SLA-Ausnahme"@de ;
  skos:definition "A condition, event, period, or responsibility that is excluded from SLA calculations."@en .

sla:MaintenanceWindow a owl:Class ;
  rdfs:subClassOf sla:SLAExclusion ;
  rdfs:label "Maintenance window"@en, "Wartungsfenster"@de .

sla:ForceMajeureExclusion a owl:Class ;
  rdfs:subClassOf sla:SLAExclusion ;
  rdfs:label "Force majeure exclusion"@en, "Hoehere-Gewalt-Ausnahme"@de .

sla:CustomerCausedExclusion a owl:Class ;
  rdfs:subClassOf sla:SLAExclusion ;
  rdfs:label "Customer-caused exclusion"@en, "Kundenseitig verursachte Ausnahme"@de .

sla:SLAReport a owl:Class ;
  rdfs:label "SLA report"@en, "SLA-Bericht"@de ;
  skos:definition "A periodic or event-driven report containing SLA performance, breach status, evidence references, service credits, and open corrective actions."@en .

sla:AuditEvidence a owl:Class ;
  rdfs:label "Audit evidence"@en, "Audit-Nachweis"@de ;
  skos:definition "Evidence that supports an SLA measurement, breach decision, remedy, or dispute resolution process."@en .

sla:MetricUnit a owl:Class ;
  rdfs:label "Metric unit"@en, "Metrikeinheit"@de .

sla:ComparisonOperator a owl:Class ;
  rdfs:label "Comparison operator"@en, "Vergleichsoperator"@de .

sla:hasParty a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range dcs:CompanyParty ;
  rdfs:label "has party"@en, "hat Partei"@de .

sla:hasProvider a owl:ObjectProperty ;
  rdfs:subPropertyOf sla:hasParty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range dcs:CompanyParty ;
  rdfs:label "has provider"@en, "hat Anbieter"@de .

sla:hasCustomer a owl:ObjectProperty ;
  rdfs:subPropertyOf sla:hasParty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range dcs:CompanyParty ;
  rdfs:label "has customer"@en, "hat Kunde"@de .

sla:coversService a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range dcs:Service ;
  rdfs:label "covers service"@en, "deckt Service ab"@de .

sla:hasServiceLevelObjective a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:ServiceLevelObjective ;
  rdfs:label "has service level objective"@en, "hat Service-Level-Ziel"@de .

sla:hasMetric a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelObjective ;
  rdfs:range sla:SLAMetric ;
  rdfs:label "has metric"@en, "hat Metrik"@de .

sla:hasThreshold a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelObjective ;
  rdfs:range sla:Threshold ;
  rdfs:label "has threshold"@en, "hat Schwellwert"@de .

sla:hasMeasurementMethod a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelObjective ;
  rdfs:range sla:MeasurementMethod ;
  rdfs:label "has measurement method"@en, "hat Messmethode"@de .

sla:hasMeasurementWindow a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelObjective ;
  rdfs:range sla:MeasurementWindow ;
  rdfs:label "has measurement window"@en, "hat Messzeitraum"@de .

sla:hasMonitoringSource a owl:ObjectProperty ;
  rdfs:domain sla:MeasurementMethod ;
  rdfs:range sla:MonitoringSource ;
  rdfs:label "has monitoring source"@en, "hat Monitoring-Quelle"@de .

sla:hasBreach a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:SLABreach ;
  rdfs:label "has breach"@en, "hat Verletzung"@de .

sla:hasRemedy a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:Remedy ;
  rdfs:label "has remedy"@en, "hat Abhilfe"@de .

sla:hasServiceCredit a owl:ObjectProperty ;
  rdfs:subPropertyOf sla:hasRemedy ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:ServiceCredit ;
  rdfs:label "has service credit"@en, "hat Service Credit"@de .

sla:hasEscalationPolicy a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:EscalationPolicy ;
  rdfs:label "has escalation policy"@en, "hat Eskalationsregel"@de .

sla:hasIncidentSeverity a owl:ObjectProperty ;
  rdfs:domain sla:Incident ;
  rdfs:range sla:IncidentSeverity ;
  rdfs:label "has incident severity"@en, "hat Incident-Schweregrad"@de .

sla:hasSupportWindow a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:SupportWindow ;
  rdfs:label "has support window"@en, "hat Supportfenster"@de .

sla:hasExclusion a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:SLAExclusion ;
  rdfs:label "has exclusion"@en, "hat Ausnahme"@de .

sla:hasReport a owl:ObjectProperty ;
  rdfs:domain sla:ServiceLevelAgreement ;
  rdfs:range sla:SLAReport ;
  rdfs:label "has report"@en, "hat Bericht"@de .

sla:hasAuditEvidence a owl:ObjectProperty ;
  rdfs:range sla:AuditEvidence ;
  rdfs:label "has audit evidence"@en, "hat Audit-Nachweis"@de .

sla:hasUnit a owl:ObjectProperty ;
  rdfs:domain sla:SLAMetric ;
  rdfs:range sla:MetricUnit ;
  rdfs:label "has unit"@en, "hat Einheit"@de .

sla:hasOperator a owl:ObjectProperty ;
  rdfs:domain sla:Threshold ;
  rdfs:range sla:ComparisonOperator ;
  rdfs:label "has operator"@en, "hat Operator"@de .

sla:hasTargetValue a owl:DatatypeProperty ;
  rdfs:domain sla:Threshold ;
  rdfs:label "has target value"@en, "hat Zielwert"@de .

sla:hasActualValue a owl:DatatypeProperty ;
  rdfs:domain sla:ServiceLevelIndicator ;
  rdfs:label "has actual value"@en, "hat Istwert"@de .

sla:hasDuration a owl:DatatypeProperty ;
  rdfs:range xsd:duration ;
  rdfs:label "has duration"@en, "hat Dauer"@de .

sla:hasCalculationFormula a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "has calculation formula"@en, "hat Berechnungsformel"@de .

sla:hasReviewFrequency a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "has review frequency"@en, "hat Prueffrequenz"@de .

sla:hasCurrency a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:label "has currency"@en, "hat Waehrung"@de .

sla:isCumulative a owl:DatatypeProperty ;
  rdfs:range xsd:boolean ;
  rdfs:label "is cumulative"@en, "ist kumulativ"@de .

sla:isCustomerReportable a owl:DatatypeProperty ;
  rdfs:range xsd:boolean ;
  rdfs:label "is customer reportable"@en, "ist kundenberichtspflichtig"@de .

slat:operator-greater-than-or-equal a sla:ComparisonOperator ;
  skos:prefLabel "greater than or equal"@en, "groesser gleich"@de .

slat:operator-less-than-or-equal a sla:ComparisonOperator ;
  skos:prefLabel "less than or equal"@en, "kleiner gleich"@de .

slat:operator-equal a sla:ComparisonOperator ;
  skos:prefLabel "equal"@en, "gleich"@de .

slat:unit-percent a sla:MetricUnit ;
  skos:prefLabel "percent"@en, "Prozent"@de .

slat:unit-minute a sla:MetricUnit ;
  skos:prefLabel "minute"@en, "Minute"@de .

slat:unit-hour a sla:MetricUnit ;
  skos:prefLabel "hour"@en, "Stunde"@de .

slat:unit-millisecond a sla:MetricUnit ;
  skos:prefLabel "millisecond"@en, "Millisekunde"@de .

slat:unit-incident a sla:MetricUnit ;
  skos:prefLabel "incident"@en, "Incident"@de .

slat:metric-availability-percent a sla:AvailabilityMetric ;
  skos:prefLabel "availability percentage"@en, "Verfuegbarkeit in Prozent"@de ;
  sla:hasUnit slat:unit-percent ;
  sla:hasCalculationFormula "((measurementWindowDuration - excludedDowntime - countedDowntime) / (measurementWindowDuration - excludedDowntime)) * 100" .

slat:metric-response-time-minutes a sla:ResponseTimeMetric ;
  skos:prefLabel "response time in minutes"@en, "Reaktionszeit in Minuten"@de ;
  sla:hasUnit slat:unit-minute ;
  sla:hasCalculationFormula "firstProviderResponseTimestamp - incidentOpenTimestamp" .

slat:metric-resolution-time-minutes a sla:ResolutionTimeMetric ;
  skos:prefLabel "resolution time in minutes"@en, "Loesungszeit in Minuten"@de ;
  sla:hasUnit slat:unit-minute ;
  sla:hasCalculationFormula "resolutionTimestamp - incidentOpenTimestamp" .

slat:metric-latency-p95-ms a sla:LatencyMetric ;
  skos:prefLabel "p95 latency in milliseconds"@en, "p95-Latenz in Millisekunden"@de ;
  sla:hasUnit slat:unit-millisecond ;
  sla:hasCalculationFormula "percentile(requestLatencyMilliseconds, 95)" .

slat:window-calendar-month a sla:MeasurementWindow ;
  skos:prefLabel "calendar month"@en, "Kalendermonat"@de ;
  sla:hasDuration "P1M" .

slat:window-calendar-quarter a sla:MeasurementWindow ;
  skos:prefLabel "calendar quarter"@en, "Kalenderquartal"@de ;
  sla:hasDuration "P3M" .

slat:window-rolling-30-days a sla:MeasurementWindow ;
  skos:prefLabel "rolling 30 days"@en, "rollierende 30 Tage"@de ;
  sla:hasDuration "P30D" .

slat:window-per-incident a sla:MeasurementWindow ;
  skos:prefLabel "per incident"@en, "pro Incident"@de .

slat:support-24x7 a sla:SupportWindow ;
  skos:prefLabel "24x7 support"@en, "24x7-Support"@de ;
  sla:hasBusinessDay "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" ;
  sla:hasStartTime "00:00:00" ;
  sla:hasEndTime "23:59:59" ;
  sla:hasTimeZone "UTC" .

slat:support-business-hours-europe-berlin a sla:SupportWindow ;
  skos:prefLabel "business-hours support Europe/Berlin"@en, "Support zu Geschaeftszeiten Europe/Berlin"@de ;
  sla:hasBusinessDay "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" ;
  sla:hasStartTime "09:00:00" ;
  sla:hasEndTime "17:00:00" ;
  sla:hasTimeZone "Europe/Berlin" .

slat:severity-critical a sla:IncidentSeverity ;
  skos:prefLabel "critical"@en, "kritisch"@de ;
  sla:hasPriority 1 ;
  skos:definition "Complete outage, severe security impact, or business-critical service unavailable for all or a material group of users."@en .

slat:severity-high a sla:IncidentSeverity ;
  skos:prefLabel "high"@en, "hoch"@de ;
  sla:hasPriority 2 ;
  skos:definition "Major degradation or partial outage with significant operational impact."@en .

slat:severity-medium a sla:IncidentSeverity ;
  skos:prefLabel "medium"@en, "mittel"@de ;
  sla:hasPriority 3 ;
  skos:definition "Limited degradation, workaround available, or non-critical operational impact."@en .

slat:severity-low a sla:IncidentSeverity ;
  skos:prefLabel "low"@en, "niedrig"@de ;
  sla:hasPriority 4 ;
  skos:definition "Minor issue, information request, or cosmetic defect without material operational impact."@en .

slat:method-provider-monitoring a sla:MeasurementMethod ;
  skos:prefLabel "provider monitoring"@en, "Provider-Monitoring"@de ;
  skos:definition "Measurements are derived from provider-operated monitoring systems and retained as audit evidence."@en .

slat:method-customer-monitoring a sla:MeasurementMethod ;
  skos:prefLabel "customer monitoring"@en, "Kunden-Monitoring"@de ;
  skos:definition "Measurements are derived from customer-operated monitoring systems, subject to agreed data quality and dispute rules."@en .

slat:method-third-party-monitoring a sla:MeasurementMethod ;
  skos:prefLabel "third-party monitoring"@en, "Drittanbieter-Monitoring"@de ;
  skos:definition "Measurements are derived from an independent monitoring or audit provider."@en .

slat:remedy-service-credit a sla:ServiceCredit ;
  skos:prefLabel "service credit"@en, "Service Credit"@de ;
  sla:hasCurrency "EUR" ;
  sla:isCumulative false ;
  skos:definition "Credit against recurring service fees, calculated according to the applicable breach tier and capped by the agreed maximum."@en .

slat:remedy-corrective-action-plan a sla:CorrectiveActionPlan ;
  skos:prefLabel "corrective action plan"@en, "Massnahmenplan"@de ;
  skos:definition "Provider must document root cause, corrective actions, owner, due date, and prevention measures after a material breach."@en .

slat:remedy-termination-for-chronic-breach a sla:TerminationRight ;
  skos:prefLabel "termination for chronic breach"@en, "Kuendigung bei wiederholter Verletzung"@de ;
  skos:definition "Customer may terminate if the same material SLA is breached repeatedly within the agreed look-back period."@en .

slat:exclusion-planned-maintenance a sla:MaintenanceWindow ;
  skos:prefLabel "planned maintenance"@en, "geplante Wartung"@de ;
  skos:definition "Pre-announced maintenance windows are excluded from availability calculations if notification and duration rules are met."@en .

slat:exclusion-force-majeure a sla:ForceMajeureExclusion ;
  skos:prefLabel "force majeure"@en, "hoehere Gewalt"@de .

slat:exclusion-customer-action a sla:CustomerCausedExclusion ;
  skos:prefLabel "customer-caused issue"@en, "kundenseitig verursachtes Problem"@de .

slat:constraint-availability-percent a dcs:ValueConstraint ;
  dcs:minInclusive 0 ;
  dcs:maxInclusive 100 ;
  dcs:format "percentage" ;
  rdfs:label "SLA availability percentage constraint"@en, "SLA-Verfuegbarkeitsprozent-Constraint"@de .

slat:constraint-duration-minutes-non-negative a dcs:ValueConstraint ;
  dcs:minInclusive 0 ;
  dcs:format "duration-minutes" ;
  rdfs:label "Non-negative duration in minutes constraint"@en, "Nichtnegative Dauer in Minuten Constraint"@de .

slat:field-service-sla-availability a dcs:DomainField ;
  dcs:semanticPath "service.sla.availability" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:parameterType "decimal" ;
  dcs:hasValueConstraint slat:constraint-availability-percent ;
  rdfs:label "SLA availability"@en, "SLA-Verfuegbarkeit"@de .

slat:field-service-sla-responseTime a dcs:DomainField ;
  dcs:semanticPath "service.sla.responseTime" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:parameterType "integer" ;
  dcs:hasValueConstraint slat:constraint-duration-minutes-non-negative ;
  rdfs:label "SLA response time"@en, "SLA-Reaktionszeit"@de .

slat:field-service-sla-resolutionTime a dcs:DomainField ;
  dcs:semanticPath "service.sla.resolutionTime" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:parameterType "integer" ;
  dcs:hasValueConstraint slat:constraint-duration-minutes-non-negative ;
  rdfs:label "SLA resolution time"@en, "SLA-Loesungszeit"@de .

slat:field-service-sla-supportHours a dcs:DomainField ;
  dcs:semanticPath "service.sla.supportHours" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:parameterType "string" ;
  rdfs:label "SLA support hours"@en, "SLA-Supportzeiten"@de .

slat:block-sla-availability a dcs:BlockCatalogueEntry ;
  dcs:blockCatalogueId "facis.block.sla.availability" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:semanticPath "service.sla.availability" ;
  rdfs:label "SLA availability block"@en, "SLA-Verfuegbarkeitsblock"@de .

slat:block-sla-response-time a dcs:BlockCatalogueEntry ;
  dcs:blockCatalogueId "facis.block.sla.response-time" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:semanticPath "service.sla.responseTime" ;
  rdfs:label "SLA response-time block"@en, "SLA-Reaktionszeitblock"@de .

slat:block-sla-resolution-time a dcs:BlockCatalogueEntry ;
  dcs:blockCatalogueId "facis.block.sla.resolution-time" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:semanticPath "service.sla.resolutionTime" ;
  rdfs:label "SLA resolution-time block"@en, "SLA-Loesungszeitblock"@de .

slat:block-sla-support a dcs:BlockCatalogueEntry ;
  dcs:blockCatalogueId "facis.block.sla.support" ;
  dcs:schemaRef "facis.dcs.service.v1" ;
  dcs:semanticPath "service.sla.supportHours" ;
  rdfs:label "SLA support block"@en, "SLA-Supportblock"@de .

slat:slo-availability-99-9-monthly a sla:ServiceLevelObjective ;
  skos:prefLabel "99.9 percent monthly availability"@en, "99,9 Prozent monatliche Verfuegbarkeit"@de ;
  sla:hasMetric slat:metric-availability-percent ;
  sla:hasMeasurementWindow slat:window-calendar-month ;
  sla:hasMeasurementMethod slat:method-provider-monitoring ;
  sla:hasThreshold slat:threshold-availability-99-9 ;
  sla:isCustomerReportable true .

slat:slo-critical-response-15-minutes a sla:ServiceLevelObjective ;
  skos:prefLabel "critical incident response within 15 minutes"@en, "Reaktion auf kritischen Incident innerhalb von 15 Minuten"@de ;
  sla:hasMetric slat:metric-response-time-minutes ;
  sla:hasMeasurementWindow slat:window-per-incident ;
  sla:hasMeasurementMethod slat:method-provider-monitoring ;
  sla:hasIncidentSeverity slat:severity-critical ;
  sla:hasThreshold slat:threshold-response-critical-15 ;
  sla:isCustomerReportable true .

slat:slo-critical-resolution-240-minutes a sla:ServiceLevelObjective ;
  skos:prefLabel "critical incident resolution within 240 minutes"@en, "Loesung eines kritischen Incident innerhalb von 240 Minuten"@de ;
  sla:hasMetric slat:metric-resolution-time-minutes ;
  sla:hasMeasurementWindow slat:window-per-incident ;
  sla:hasMeasurementMethod slat:method-provider-monitoring ;
  sla:hasIncidentSeverity slat:severity-critical ;
  sla:hasThreshold slat:threshold-resolution-critical-240 ;
  sla:isCustomerReportable true .

slat:example-standard-cloud-service-sla a sla:ServiceLevelAgreement ;
  skos:prefLabel "Example standard cloud service SLA"@en, "Beispiel Standard Cloud Service SLA"@de ;
  sla:coversService dcs:Service ;
  sla:hasServiceLevelObjective slat:slo-availability-99-9-monthly, slat:slo-critical-response-15-minutes, slat:slo-critical-resolution-240-minutes ;
  sla:hasSupportWindow slat:support-24x7 ;
  sla:hasExclusion slat:exclusion-planned-maintenance, slat:exclusion-force-majeure, slat:exclusion-customer-action ;
  sla:hasRemedy slat:remedy-service-credit, slat:remedy-corrective-action-plan, slat:remedy-termination-for-chronic-breach ;
  sla:hasReviewFrequency "monthly" .

dcs:Contract a rdfs:Class ;
  rdfs:label "Contract"@en ;
  rdfs:comment "A digital contract instance managed by DCS in machine-readable and human-readable form."@en .

dcs:ContractTemplate a rdfs:Class ;
  rdfs:label "Contract Template"@en ;
  rdfs:comment "A reusable machine-readable template that can generate contract instances."@en .

dcs:ContractObject a rdfs:Class ;
  rdfs:label "Contract Object"@en ;
  rdfs:comment "A lifecycle-aware digital object containing contract content, metadata, parties, semantic conditions, and evidence."@en .

dcs:ContractVersion a rdfs:Class ;
  rdfs:label "Contract Version"@en ;
  rdfs:comment "A version of a contract created by generation, adjustment, renewal, or correction."@en .

dcs:Section a rdfs:Class ;
  rdfs:label "Section"@en ;
  rdfs:comment "A structural section in a contract document outline."@en .

dcs:Clause a rdfs:Class ;
  rdfs:label "Clause"@en ;
  rdfs:comment "A clause-level unit that may be versioned, negotiated, and linked to semantic conditions."@en .

dcs:ContractCondition a rdfs:Class ;
  rdfs:label "Contract Condition"@en ;
  rdfs:comment "A contractual condition, obligation, policy, or regulatory requirement."@en .

dcs:SemanticCondition a rdfs:Class ;
  rdfs:subClassOf dcs:ContractCondition ;
  rdfs:label "Semantic Condition"@en ;
  rdfs:comment "A machine-readable condition used for automated validation or policy extraction."@en .

dcs:SLAAgreement a rdfs:Class ;
  rdfs:label "SLA Agreement"@en .

