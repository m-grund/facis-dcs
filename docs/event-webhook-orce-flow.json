    {
        "id": "fn-dispatch",
        "type": "function",
        "z": "tab-dcs-test",
        "name": "Verify + Auto-Callback",
        "func": "var secret = env.get('WEBHOOK_SECRET') || '';\nvar auth   = (msg.req.headers['authorization'] || '').replace('Bearer ','');\nif (secret && auth !== secret) {\n    node.send([{payload:{error:'unauthorized'},statusCode:401,res:msg.res}, null, null]);\n    return null;\n}\nvar d = msg.payload;\n\n// Out 1: HTTP 200 to caller\nvar resp = {payload:{status:'received'}, statusCode:200, res:msg.res};\n\n// Out 2: callback to DCS\nvar token  = flow.get('dcs_token') || flow.get('mock_token');\nvar dcsURL = flow.get('dcs_url') || env.get('DCS_URL') || 'http://host.docker.internal:8991';\nvar cb = token ? {\n    url:    dcsURL + '/orce/callbacks',\n    method: 'POST',\n    headers: {'Authorization':'Bearer '+token,'Content-Type':'application/json'},\n    payload: {event_id:d.event_id, status:'completed', result:{event:d.event, did:d.did}}\n} : null;\n\n// Out 3: debug\nnode.send([resp, cb, {payload:d}]);\nreturn null;",
        "outputs": 3,
        "timeout": "",
