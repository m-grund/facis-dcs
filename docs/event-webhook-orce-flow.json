    {
        "id": "sf-fn-token",
        "type": "function",
        "z": "sf-dcs-subscribe",
        "name": "Get token (mock or Keycloak)",
        "func": "var useMock = env.get('JWT_ALG_NONE_SUPPORTED');\nif (useMock === true || useMock === 'true') {\n    var clientId = env.get('JWT_CLIENT_ID') || 'dcs-client';\n    var username = env.get('JWT_USERNAME')  || 'bdd-orce';\n    var role     = env.get('JWT_ROLE')      || 'Template Creator';\n    var issuer   = env.get('JWT_ISSUER')    || 'https://auth.eclipse.org/auth/realms/community';\n    function b64url(obj) {\n        return Buffer.from(JSON.stringify(obj)).toString('base64url');\n    }\n    var header = { alg: 'none' };\n    var resource = {};\n    resource[clientId] = { roles: [role] };\n    var payload = {\n        sub: username,\n        iss: issuer,\n        azp: clientId,\n        resource_access: resource,\n        exp: 9999999999\n    };\n    msg.payload = { access_token: b64url(header) + '.' + b64url(payload) + '.' };\n    return [msg, null];\n}\nvar KEYCLOAK_URL  = env.get('KEYCLOAK_URL')  || 'http://dcs-keycloak:8080/realms/gaia-x/protocol/openid-connect/token';\nvar CLIENT_ID     = env.get('CLIENT_ID')     || 'federated-catalogue';\nvar CLIENT_SECRET = env.get('CLIENT_SECRET') || 'federated-catalogue-secret';\nmsg.url     = KEYCLOAK_URL;\nmsg.method  = 'POST';\nmsg.headers = {\n    'Content-Type': 'application/x-www-form-urlencoded',\n    'Host': 'localhost:30080'\n};\nmsg.payload = 'grant_type=client_credentials'\n    + '&client_id='     + encodeURIComponent(CLIENT_ID)\n    + '&client_secret=' + encodeURIComponent(CLIENT_SECRET);\nreturn [null, msg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 120,
        "wires": [
            [
                "sf-fn-subscribe"
            ],
            [
                "sf-http-token"
            ]
        ]
    },
