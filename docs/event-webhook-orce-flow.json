    {
        "id": "sf-fn-subscribe",
        "type": "function",
        "z": "sf-dcs-subscribe",
        "name": "Build subscribe req",
        "func": "var DCS_URL      = env.get('DCS_URL')      || 'http://host.docker.internal:8991';\nvar EVENT        = env.get('EVENT')        || 'template.created';\nvar CALLBACK_URL = env.get('CALLBACK_URL') || 'http://dcs-orce:1880/dcs-dispatch';\nvar SECRET       = env.get('WEBHOOK_SECRET') || '';\nif (!msg.payload || !msg.payload.access_token) {\n    return [null, {payload:{ok:false,error:'token_failed',body:msg.payload}}];\n}\nflow.set('dcs_token', msg.payload.access_token);\nflow.set('dcs_url', DCS_URL);\nmsg.url    = DCS_URL + '/orce/webhooks';\nmsg.method = 'POST';\nmsg.headers = {\n    'Authorization': 'Bearer ' + 'eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJzdWIiOiJ0ZXN0IiwiaXNzIjoiaHR0cDovL2xvY2FsaG9zdDozMDA4MC9yZWFsbXMvZ2FpYS14IiwiYXpwIjoiZGNzLWNsaWVudCIsInJlc291cmNlX2FjY2VzcyI6eyJkY3MtY2xpZW50Ijp7InJvbGVzIjoiVGVtcGxhdGUgUmV2aWV3ZXIifX0sImV4cCI6IjE3ODA2MDA4MjYifQ.', //msg.payload.access_token,\n    'Content-Type':  'application/json'\n};\nmsg.payload = {\n    event:        EVENT,\n    callback_url: CALLBACK_URL,\n    secret:       SECRET\n};\nreturn [msg, null];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 717.5,
        "y": 280,
        "wires": [
