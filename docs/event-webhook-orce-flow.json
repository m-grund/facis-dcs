    {
        "id": "sf-fn-result",
        "type": "function",
        "z": "sf-dcs-subscribe",
        "name": "Format result",
        "func": "if (msg.payload && msg.payload.ok === false) { return [null, msg]; }\nif (msg.statusCode === 201) {\n    var s = flow.get('dcs_subscriptions') || {};\n    s[msg.payload.event] = msg.payload.id;\n    flow.set('dcs_subscriptions', s);\n    return [{payload:{ok:true, id:msg.payload.id, event:msg.payload.event}}, null];\n}\nreturn [null, {payload:{ok:false, status:msg.statusCode, body:msg.payload}}];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
