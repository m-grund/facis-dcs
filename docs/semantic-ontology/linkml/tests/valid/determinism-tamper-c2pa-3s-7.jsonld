      }
    ],
    "blocks": [
      {
        "@type": "Section",
        "@id": "urn:doc:tamper-c2pa#s1",
        "title": "1. Deposit"
      },
      {
        "@type": "Clause",
        "@id": "urn:doc:tamper-c2pa#c1",
        "content": [
          "The Depositor shall place the Source Code into escrow within thirty (30) days of execution."
        ]
      },
      {
        "@type": "Clause",
        "@id": "urn:doc:tamper-c2pa#c2",
        "content": [
          "The Escrow Agent shall acknowledge receipt in writing."
        ]
      },
      {
        "@type": "Section",
        "@id": "urn:doc:tamper-c2pa#s1-1",
        "title": "1.1 Verification of Deposit"
      },
      {
        "@type": "Clause",
        "@id": "urn:doc:tamper-c2pa#c3",
        "content": [
          "The Beneficiary may request a technical verification of the deposited materials once per year."
        ]
      },
      {
        "@type": "Section",
        "@id": "urn:doc:tamper-c2pa#s2",
        "title": "2. Release Conditions"
      },
      {
        "@type": "Clause",
        "@id": "urn:doc:tamper-c2pa#c4",
        "content": [
          "Escrow materials shall be released upon insolvency of the Depositor."
        ]
      },
      {
        "@type": "Clause",
        "@id": "urn:doc:tamper-c2pa#c5",
        "content": [
          "A written request from the Beneficiary is required to trigger release."
        ]
      }
    ]
  }
}