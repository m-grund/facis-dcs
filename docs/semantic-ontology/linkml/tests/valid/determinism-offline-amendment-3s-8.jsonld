  "@type": "ContractTemplate",
  "documentTitle": "Distribution Agreement",
  "metadata": {
    "@type": "TemplateMetadata",
    "title": "Distribution Agreement"
  },
  "documentStructure": {
    "@type": "DocumentStructure",
    "layout": [
      {
        "@type": "LayoutNode",
        "isRoot": true,
        "children": [
          "urn:doc:offline-amendment#s1",
