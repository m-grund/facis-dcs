@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcs:Clause a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:title ] ;
    sh:targetClass dcs:Clause .

dcs:ContractTemplate a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcs:TemplateMetadata ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path dcs:metadata ],
        [ sh:class dcs:SignatureField ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path dcs:signatureFields ],
        [ sh:class dcs:DocumentStructure ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path dcs:documentStructure ],
        [ sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcs:policies ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:documentTitle ],
        [ sh:class dcs:Placeholder ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path dcs:contractData ] ;
    sh:targetClass dcs:ContractTemplate .

dcs:KPIObservationSet a sh:NodeShape ;
    rdfs:comment "The KPI observations reported for one contract." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcs:KPIObservation ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path dcs:observation ] ;
    sh:targetClass dcs:KPIObservationSet .

dcs:Section a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:title ] ;
    sh:targetClass dcs:Section .

dcs:TextBlock a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:text ] ;
    sh:targetClass dcs:TextBlock .

dcs:DocumentStructure a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcs:LayoutNode ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path dcs:layout ] ;
    sh:targetClass dcs:DocumentStructure .

dcs:KPIObservation a sh:NodeShape ;
    rdfs:comment "One KPI value a contract target system reported for a deployed contract." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcs:observedAt ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcs:metricName ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dcs:aboutContract ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the observed value violates an obligation the contract's own ODRL policies declare for the metric." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcs:violation ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcs:observedValue ] ;
    sh:targetClass dcs:KPIObservation .

dcs:LayoutNode a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:isRoot ] ;
    sh:targetClass dcs:LayoutNode .

dcs:Placeholder a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The human-readable label for the placeholder field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:label ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcs:required ],
        [ sh:datatype xsd:string ;
            sh:description "The literal datatype of the placeholder value, e.g. \"xsd:decimal\"; carried inline from the shape's sh:datatype." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcs:datatype ],
        [ sh:description "The SHACL shape this placeholder's value is typed by." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path dcs:shape ] ;
    sh:targetClass dcs:Placeholder .

dcs:SignatureField a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcs:title ],
        [ sh:datatype xsd:string ;
            sh:description "Machine-readable identifier for the signatory role; used as the AcroForm /T field name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:signatoryName ] ;
    sh:targetClass dcs:SignatureField .

dcs:TemplateMetadata a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dcs:title ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcs:name ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcs:updatedAt ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcs:description ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcs:templateVersion ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcs:did ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcs:uuid ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcs:schemaVersion ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs:createdAt ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcs:templateType ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcs:sourceSystemType ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcs:createdBy ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcs:state ] ;
    sh:targetClass dcs:TemplateMetadata .


@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# gen-shacl cannot model rdf:List member validation: it emits sh:or directly
# on the property path, which sees only the list-head blank node and fails.
# These shapes use the property path  p / rdf:rest* / rdf:first  to iterate
# every member of an @list and validate each member individually.
# The corresponding slots (content, blocks, children) are intentionally omitted
# from their parent class's slot list in linkml.yaml so gen-shacl emits no
# conflicting constraint.

dcs:Clause sh:property [
    sh:path ( dcs:content [ sh:zeroOrMorePath rdf:rest ] rdf:first ) ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:class dcs:Placeholder ]
    )
] .

dcs:DocumentStructure sh:property [
    sh:path ( dcs:blocks [ sh:zeroOrMorePath rdf:rest ] rdf:first ) ;
    sh:or (
        [ sh:class dcs:Clause ]
        [ sh:class dcs:Section ]
        [ sh:class dcs:TextBlock ]
    )
] .

dcs:LayoutNode sh:property [
    sh:path ( dcs:children [ sh:zeroOrMorePath rdf:rest ] rdf:first ) ;
    sh:nodeKind sh:IRI
] .

dcs:SignatureField sh:nodeKind sh:IRI .
