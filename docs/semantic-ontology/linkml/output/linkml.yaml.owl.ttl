@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcs:blockId a owl:DatatypeProperty ;
    rdfs:label "blockId" ;
    rdfs:range xsd:string ;
    skos:definition "The document block the value was captured in." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:blocks a owl:DatatypeProperty ;
    rdfs:label "blocks" ;
    rdfs:range [ owl:unionOf ( dcs:Clause dcs:Section dcs:TextBlock ) ] ;
    skos:closeMatch <http://schema.org/hasPart> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:children a owl:DatatypeProperty ;
    rdfs:label "children" ;
    rdfs:range [ owl:unionOf ( dcs:LayoutNode dcs:Section dcs:Clause dcs:TextBlock ) ] ;
    skos:closeMatch <http://schema.org/hasPart> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:content a owl:DatatypeProperty ;
    rdfs:label "content" ;
    rdfs:range [ owl:unionOf ( xsd:string dcs:Placeholder ) ] ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:contractData a owl:ObjectProperty ;
    rdfs:label "contractData" ;
    rdfs:range dcs:Placeholder ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:derivedFromTemplate a owl:DatatypeProperty ;
    rdfs:label "derivedFromTemplate" ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    skos:definition "The template this contract instance was derived from." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:layout a owl:ObjectProperty ;
    rdfs:label "layout" ;
    rdfs:range dcs:LayoutNode ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:observation a owl:ObjectProperty ;
    rdfs:label "observation" ;
    rdfs:range dcs:KPIObservation ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:policies a owl:DatatypeProperty ;
    rdfs:label "policies" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch odrl:hasPolicy ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:prose a owl:DatatypeProperty ;
    rdfs:label "prose" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch dcterms:source ;
    skos:definition "The human-readable clause node this machine-readable rule is backed by; every ODRL rule a document carries must reference the audited prose it operationalizes." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:renewsContract a owl:DatatypeProperty ;
    rdfs:label "renewsContract" ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf prov:wasRevisionOf ;
    skos:definition "The prior contract instance this renewal supersedes." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:semanticPath a owl:DatatypeProperty ;
    rdfs:label "semanticPath" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:signatureFields a owl:ObjectProperty ;
    rdfs:label "signatureFields" ;
    rdfs:range dcs:SignatureField ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

<https://w3id.org/facis/dcs/schema.owl.ttl> a owl:Ontology ;
    rdfs:label "dcs-schema" ;
    skos:definition "Digital Contracting Service semantic schema" .

prov:wasDerivedFrom a owl:DatatypeProperty ;
    rdfs:label "wasDerivedFrom" ;
    rdfs:range xsd:anyURI ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

prov:wasRevisionOf a owl:DatatypeProperty ;
    rdfs:label "wasRevisionOf" ;
    rdfs:range xsd:anyURI ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:ContractTemplate a owl:Class ;
    rdfs:label "ContractTemplate" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:metadata ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:documentStructure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:documentTitle ] ;
    skos:closeMatch <http://schema.org/CreativeWork> ;
    skos:exactMatch dcs:ContractTemplate ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:KPIObservationSet a owl:Class ;
    rdfs:label "KPIObservationSet" ;
    skos:definition "The KPI observations reported for one contract." ;
    skos:exactMatch dcs:KPIObservationSet ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:aboutContract a owl:DatatypeProperty ;
    rdfs:label "aboutContract" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch <http://schema.org/about> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:created ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:createdBy a owl:DatatypeProperty ;
    rdfs:label "createdBy" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:creator ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:datatype a owl:DatatypeProperty ;
    rdfs:label "datatype" ;
    rdfs:range xsd:string ;
    skos:definition "The literal datatype of the placeholder value, e.g. \"xsd:decimal\"; carried inline from the shape's sh:datatype." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:description ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:did a owl:DatatypeProperty ;
    rdfs:label "did" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:identifier ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:documentStructure a owl:ObjectProperty ;
    rdfs:label "documentStructure" ;
    rdfs:range dcs:DocumentStructure ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:documentTitle a owl:DatatypeProperty ;
    rdfs:label "documentTitle" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:isRoot a owl:DatatypeProperty ;
    rdfs:label "isRoot" ;
    rdfs:range xsd:boolean ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:label a owl:DatatypeProperty ;
    rdfs:label "label" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/name> ;
    skos:definition "The human-readable label for the placeholder field." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:metadata a owl:ObjectProperty ;
    rdfs:label "metadata" ;
    rdfs:range dcs:TemplateMetadata ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:metricName a owl:DatatypeProperty ;
    rdfs:label "metricName" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/name> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/name> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:observedAt a owl:DatatypeProperty ;
    rdfs:label "observedAt" ;
    rdfs:range xsd:dateTime ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:observedValue a owl:DatatypeProperty ;
    rdfs:label "observedValue" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/value> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:required a owl:DatatypeProperty ;
    rdfs:label "required" ;
    rdfs:range xsd:boolean ;
    skos:closeMatch <http://schema.org/valueRequired> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:schemaVersion a owl:DatatypeProperty ;
    rdfs:label "schemaVersion" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/schemaVersion> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:shape a owl:DatatypeProperty ;
    rdfs:label "shape" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The SHACL shape this placeholder's value is typed by." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:signatoryName a owl:DatatypeProperty ;
    rdfs:label "signatoryName" ;
    rdfs:range xsd:string ;
    skos:definition "Machine-readable identifier for the signatory role; used as the AcroForm /T field name." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:sourceSystemType a owl:DatatypeProperty ;
    rdfs:label "sourceSystemType" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:state a owl:DatatypeProperty ;
    rdfs:label "state" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:templateType a owl:DatatypeProperty ;
    rdfs:label "templateType" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:type ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:templateVersion a owl:DatatypeProperty ;
    rdfs:label "templateVersion" ;
    rdfs:range xsd:integer ;
    skos:closeMatch <http://schema.org/version> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:range xsd:string ;
    skos:closeMatch <http://schema.org/text> ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:updatedAt a owl:DatatypeProperty ;
    rdfs:label "updatedAt" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:modified ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:uuid a owl:DatatypeProperty ;
    rdfs:label "uuid" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:identifier ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:violation a owl:DatatypeProperty ;
    rdfs:label "violation" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the observed value violates an obligation the contract's own ODRL policies declare for the metric." ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:DocumentStructure a owl:Class ;
    rdfs:label "DocumentStructure" ;
    skos:exactMatch dcs:DocumentStructure ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:KPIObservation a owl:Class ;
    rdfs:label "KPIObservation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:observedValue ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:aboutContract ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:metricName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:violation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:observedAt ] ;
    skos:closeMatch <http://schema.org/Observation> ;
    skos:definition "One KPI value a contract target system reported for a deployed contract." ;
    skos:exactMatch dcs:KPIObservation ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:SignatureField a owl:Class ;
    rdfs:label "SignatureField" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:signatoryName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:title ] ;
    skos:exactMatch dcs:SignatureField ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:TemplateMetadata a owl:Class ;
    rdfs:label "TemplateMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:did ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:templateVersion ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:updatedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:sourceSystemType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:createdAt ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:createdBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:schemaVersion ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:templateType ] ;
    skos:exactMatch dcs:TemplateMetadata ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Clause a owl:Class ;
    rdfs:label "Clause" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:title ] ;
    skos:closeMatch <http://schema.org/Article> ;
    skos:exactMatch dcs:Clause ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:LayoutNode a owl:Class ;
    rdfs:label "LayoutNode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:isRoot ] ;
    skos:exactMatch dcs:LayoutNode ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Placeholder a owl:Class ;
    rdfs:label "Placeholder" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:datatype ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:required ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:shape ] ;
    skos:exactMatch dcs:Placeholder ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Section a owl:Class ;
    rdfs:label "Section" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:title ] ;
    skos:closeMatch <http://schema.org/Article> ;
    skos:exactMatch dcs:Section ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:TextBlock a owl:Class ;
    rdfs:label "TextBlock" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:text ] ;
    skos:closeMatch <http://schema.org/Text> ;
    skos:exactMatch dcs:TextBlock ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:title ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .


