@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcs:blocks a owl:DatatypeProperty ;
    rdfs:label "blocks" ;
    rdfs:range [ owl:unionOf ( dcs:Clause dcs:Section dcs:TextBlock ) ] ;
    skos:closeMatch schema1:hasPart ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:children a owl:DatatypeProperty ;
    rdfs:label "children" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch schema1:hasPart ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:content a owl:DatatypeProperty ;
    rdfs:label "content" ;
    rdfs:range [ owl:unionOf ( xsd:string dcs:Placeholder ) ] ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:contractData a owl:ObjectProperty ;
    rdfs:label "contractData" ;
    rdfs:range dcs:DataRequirement ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:layout a owl:ObjectProperty ;
    rdfs:label "layout" ;
    rdfs:range dcs:LayoutNode ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:policies a owl:DatatypeProperty ;
    rdfs:label "policies" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch odrl:hasPolicy ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:semanticPath a owl:DatatypeProperty ;
    rdfs:label "semanticPath" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

<https://w3id.org/facis/dcs/schema.owl.ttl> a owl:Ontology ;
    rdfs:label "dcs-schema" ;
    skos:definition "Digital Contracting Service semantic schema" .

dcs:ContractTemplate a owl:Class ;
    rdfs:label "ContractTemplate" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:documentStructure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:documentTitle ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:metadata ] ;
    skos:closeMatch schema1:CreativeWork ;
    skos:exactMatch dcs:ContractTemplate ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:bindsTo a owl:ObjectProperty ;
    rdfs:label "bindsTo" ;
    rdfs:range dcs:RequirementField ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:conditionId a owl:DatatypeProperty ;
    rdfs:label "conditionId" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:created ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:createdBy a owl:DatatypeProperty ;
    rdfs:label "createdBy" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:creator ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:description ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:did a owl:DatatypeProperty ;
    rdfs:label "did" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:identifier ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:documentStructure a owl:ObjectProperty ;
    rdfs:label "documentStructure" ;
    rdfs:range dcs:DocumentStructure ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:documentTitle a owl:DatatypeProperty ;
    rdfs:label "documentTitle" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:domainField a owl:DatatypeProperty ;
    rdfs:label "domainField" ;
    rdfs:range xsd:anyURI ;
    skos:closeMatch schema1:propertyID ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:fields a owl:ObjectProperty ;
    rdfs:label "fields" ;
    rdfs:range dcs:RequirementField ;
    skos:closeMatch schema1:property ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:isRoot a owl:DatatypeProperty ;
    rdfs:label "isRoot" ;
    rdfs:range xsd:boolean ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:metadata a owl:ObjectProperty ;
    rdfs:label "metadata" ;
    rdfs:range dcs:TemplateMetadata ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:parameterName a owl:DatatypeProperty ;
    rdfs:label "parameterName" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:required a owl:DatatypeProperty ;
    rdfs:label "required" ;
    rdfs:range xsd:boolean ;
    skos:closeMatch schema1:valueRequired ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:sourceSystemType a owl:DatatypeProperty ;
    rdfs:label "sourceSystemType" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:state a owl:DatatypeProperty ;
    rdfs:label "state" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:templateType a owl:DatatypeProperty ;
    rdfs:label "templateType" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:type ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:templateVersion a owl:DatatypeProperty ;
    rdfs:label "templateVersion" ;
    rdfs:range xsd:integer ;
    skos:closeMatch schema1:version ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:range xsd:string ;
    skos:closeMatch schema1:text ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:token a owl:DatatypeProperty ;
    rdfs:label "token" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:updatedAt a owl:DatatypeProperty ;
    rdfs:label "updatedAt" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:modified ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:uuid a owl:DatatypeProperty ;
    rdfs:label "uuid" ;
    rdfs:range xsd:string ;
    skos:closeMatch dcterms:identifier ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Clause a owl:Class ;
    rdfs:label "Clause" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:title ] ;
    skos:closeMatch schema1:Article ;
    skos:exactMatch dcs:Clause ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:DataRequirement a owl:Class ;
    rdfs:label "DataRequirement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:schemaVersion ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:conditionId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty dcs:fields ] ;
    skos:exactMatch dcs:DataRequirement ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:DocumentStructure a owl:Class ;
    rdfs:label "DocumentStructure" ;
    skos:exactMatch dcs:DocumentStructure ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:LayoutNode a owl:Class ;
    rdfs:label "LayoutNode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:isRoot ] ;
    skos:exactMatch dcs:LayoutNode ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Placeholder a owl:Class ;
    rdfs:label "Placeholder" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:bindsTo ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:token ] ;
    skos:exactMatch dcs:Placeholder ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:Section a owl:Class ;
    rdfs:label "Section" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:title ] ;
    skos:closeMatch schema1:Article ;
    skos:exactMatch dcs:Section ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:TemplateMetadata a owl:Class ;
    rdfs:label "TemplateMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:createdBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:updatedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:templateVersion ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:templateType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:sourceSystemType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:name ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:createdAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:did ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:schemaVersion ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:uuid ] ;
    skos:exactMatch dcs:TemplateMetadata ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:TextBlock a owl:Class ;
    rdfs:label "TextBlock" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:text ] ;
    skos:closeMatch schema1:Text ;
    skos:exactMatch dcs:TextBlock ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:closeMatch schema1:name ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:schemaVersion a owl:DatatypeProperty ;
    rdfs:label "schemaVersion" ;
    rdfs:range xsd:string ;
    skos:closeMatch schema1:schemaVersion ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:RequirementField a owl:Class ;
    rdfs:label "RequirementField" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:domainField ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty dcs:required ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty dcs:parameterName ] ;
    skos:closeMatch schema1:PropertyValue ;
    skos:exactMatch dcs:RequirementField ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .

dcs:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:exactMatch dcterms:title ;
    skos:inScheme <https://w3id.org/facis/dcs/schema> .


