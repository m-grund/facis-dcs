@prefix dcs:  <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<https://w3id.org/facis/dcs/shapes/v1>
  a sh:NodeShape ;
  sh:description "FACIS DCS starter SHACL package. Shapes are external validation assets and are not required for runtime operation." .

dcs:ContractShape
  a sh:NodeShape ;
  sh:targetClass dcs:Contract ;
  sh:property [
    sh:path dcs:did ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "A contract requires a stable DID." ;
  ] ;
  sh:property [
    sh:path dcs:contractVersion ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 1 ;
  ] ;
  sh:property [
    sh:path dcs:state ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:derivedFromTemplate ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:validUntil ;
    sh:datatype xsd:dateTime ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:party ;
    sh:class dcs:Company ;
    sh:node dcs:CompanyShape ;
    sh:minCount 2 ;
  ] .

dcs:CompanyShape
  a sh:NodeShape ;
  sh:targetClass dcs:Company ;
  sh:property [
    sh:path dcs:role ;
    sh:datatype xsd:string ;
    sh:in ( "supplier" "customer" "provider" "client" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:legalName ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

dcs:ContractTemplateShape
  a sh:NodeShape ;
  sh:targetClass dcs:ContractTemplate ;
  sh:property [
    sh:path dcs:did ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:templateVersion ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 1 ;
  ] ;
  sh:property [
    sh:path dcs:schemaVersion ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

dcs:ClauseShape
  a sh:NodeShape ;
  sh:targetClass dcs:Clause ;
  sh:property [
    sh:path dcs:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:clauseVersion ;
    sh:datatype xsd:integer ;
    sh:minInclusive 1 ;
  ] .

dcs:SemanticConditionShape
  a sh:NodeShape ;
  sh:targetClass dcs:SemanticCondition ;
  sh:property [
    sh:path dcs:conditionId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:conditionName ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:schemaVersion ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:hasParameter ;
    sh:node dcs:ParameterShape ;
    sh:minCount 1 ;
  ] .

dcs:ParameterShape
  a sh:NodeShape ;
  sh:targetClass dcs:Parameter ;
  sh:property [
    sh:path dcs:parameterName ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:parameterType ;
    sh:datatype xsd:string ;
    sh:in ( "string" "decimal" "integer" "boolean" "date" "enum" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:required ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:hasConstraint ;
    sh:node dcs:ConstraintShape ;
  ] .

dcs:ConstraintShape
  a sh:NodeShape ;
  sh:targetClass dcs:Constraint ;
  sh:property [
    sh:path dcs:operator ;
    sh:in ( dcs:Equals dcs:NotEquals dcs:GreaterThan dcs:GreaterThanOrEqual dcs:LessThan dcs:LessThanOrEqual dcs:Between dcs:Contains dcs:MatchesRegex ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:rightOperand ;
    sh:minCount 1 ;
  ] .

dcs:SemanticRuleShape
  a sh:NodeShape ;
  sh:targetClass dcs:SemanticRule ;
  sh:property [
    sh:path dcs:ruleId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:leftOperand ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:operator ;
    sh:in ( dcs:Equals dcs:NotEquals dcs:GreaterThan dcs:GreaterThanOrEqual dcs:LessThan dcs:LessThanOrEqual dcs:Between dcs:Contains dcs:MatchesRegex ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

dcs:SLAAgreementShape
  a sh:NodeShape ;
  sh:targetClass dcs:SLAAgreement ;
  sh:property [
    sh:path dcs:hasService ;
    sh:node dcs:ServiceShape ;
    sh:minCount 1 ;
  ] .

dcs:ServiceShape
  a sh:NodeShape ;
  sh:targetClass dcs:Service ;
  sh:property [
    sh:path dcs:serviceId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:hasSLO ;
    sh:node dcs:SLOShape ;
    sh:minCount 1 ;
  ] .

dcs:SLOShape
  a sh:NodeShape ;
  sh:targetClass dcs:SLO ;
  sh:property [
    sh:path dcs:sloType ;
    sh:datatype xsd:string ;
    sh:in ( "availability" "responseTime" "resolutionTime" "errorRate" "throughput" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:targetValue ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

dcs:ContractAdjustmentShape
  a sh:NodeShape ;
  sh:targetClass dcs:ContractAdjustment ;
  sh:property [
    sh:path dcs:adjustmentId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:contractVersion ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:operation ;
    sh:datatype xsd:string ;
    sh:in ( "add" "remove" "replace" "move" "setValue" ) ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:targetId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] .

dcs:DeploymentShape
  a sh:NodeShape ;
  sh:targetClass dcs:Deployment ;
  sh:property [
    sh:path dcs:targetSystem ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:targetEndpoint ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:hasPolicyBundle ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:correlationId ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .

dcs:ProvenanceEventShape
  a sh:NodeShape ;
  sh:targetClass dcs:ProvenanceEvent ;
  sh:property [
    sh:path dcs:eventId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:eventType ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:actor ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs:occurredAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .
