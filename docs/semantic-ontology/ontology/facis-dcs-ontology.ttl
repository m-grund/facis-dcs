#################################################################
# Operator individuals
#################################################################

dcs:Equals a dcs:Operator ; rdfs:label "Equals" ; dcs:identifier "Equals" .
dcs:NotEquals a dcs:Operator ; rdfs:label "Not Equals" ; dcs:identifier "NotEquals" .
dcs:GreaterThan a dcs:Operator ; rdfs:label "Greater Than" ; dcs:identifier "GreaterThan" .
dcs:GreaterThanOrEqual a dcs:Operator ; rdfs:label "Greater Than Or Equal" ; dcs:identifier "GreaterThanOrEqual" .
dcs:LessThan a dcs:Operator ; rdfs:label "Less Than" ; dcs:identifier "LessThan" .
dcs:LessThanOrEqual a dcs:Operator ; rdfs:label "Less Than Or Equal" ; dcs:identifier "LessThanOrEqual" .
dcs:Between a dcs:Operator ; rdfs:label "Between" ; dcs:identifier "Between" .
dcs:Contains a dcs:Operator ; rdfs:label "Contains" ; dcs:identifier "Contains" .
dcs:MatchesRegex a dcs:Operator ; rdfs:label "Matches Regex" ; dcs:identifier "MatchesRegex" .

