          "sc-country",
          "sc-access-window"
        ],
        "version": 4,
        "contentHash": "sha256:clause-access-policy-v4"
      },
      {
        "blockId": "clause-remedy",
        "type": "CLAUSE",
        "title": "Remedy",
        "text": "If the uptime SLO is missed and no exclusion event applies, the customer may claim a service credit of 10 percent.",
