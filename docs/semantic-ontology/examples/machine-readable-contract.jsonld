            "value": "https://api.example.org/showtimes"
          }
        ]
      },
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-uptime",
        "conditionName": "Minimum monthly uptime",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "uptimePercentage",
            "type": "decimal",
            "isRequired": true,
            "operators": [
              {
                "operate": "GreaterThanOrEqual",
                "targets": [
                  "99.95"
                ]
              }
            ],
            "value": 99.95
          },
          {
            "parameterName": "measurementWindow",
            "type": "string",
            "isRequired": true,
            "operators": [
