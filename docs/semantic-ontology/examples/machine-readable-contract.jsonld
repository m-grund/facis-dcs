  "sla": {
    "@type": "SLAAgreement",
    "services": [
      {
        "@type": "Service",
        "serviceId": "showtimes-api",
        "name": "Showtimes API",
        "targetEndpoint": "https://api.example.org/showtimes",
        "slos": [
          {
            "@type": "SLO",
            "sloType": "availability",
            "targetValue": 99.95,
            "unit": "percent",
            "operator": "GreaterThanOrEqual",
            "measurementWindow": "P1M",
            "identifier": "slo-uptime-monthly",
            "name": "Monthly API uptime",
            "measurementRules": [
              {
                "@type": "MeasurementRule",
                "identifier": "mr-uptime-monthly",
                "measurementWindow": "P1M",
                "leftOperand": "$.metrics.uptime",
                "operator": "GreaterThanOrEqual",
                "rightOperand": 99.95,
                "valueType": "decimal"
              }
            ],
            "remedies": [
              {
                "@type": "ServiceCredit",
                "identifier": "credit-uptime-breach",
                "creditPercentage": 10
              }
            ]
          }
        ]
      }
    ],
    "claimPolicy": {
      "@type": "ClaimPolicy",
      "identifier": "claim-policy-standard",
      "allowedClaimWindow": "P30D"
    },
    "exclusionEvents": [
      {
        "@type": "ExclusionEvent",
        "identifier": "planned-maintenance"
      }
    ]
  },
  "semanticRules": [
    {
      "@type": "ThresholdRule",
      "ruleId": "rule-uptime-minimum",
      "leftOperand": "{{sc-uptime.uptimePercentage}}",
      "operator": "GreaterThanOrEqual",
      "rightOperand": 99.95,
      "valueType": "decimal",
      "severity": "blocking"
    },
    {
      "@type": "DateConstraintRule",
      "ruleId": "rule-expiry-in-future",
      "leftOperand": "$.validUntil",
      "operator": "GreaterThan",
      "rightOperand": "now",
      "valueType": "date",
      "severity": "blocking"
    },
    {
      "@type": "SemanticRule",
      "ruleId": "rule-organization-country-de",
      "leftOperand": "$.parties[?(@.role=='customer')].location.country",
      "operator": "Equals",
      "rightOperand": "DEU",
      "valueType": "string",
      "severity": "blocking"
    },
    {
      "@type": "DateConstraintRule",
      "ruleId": "rule-access-before-contract-end",
      "leftOperand": "$.contractData.semanticConditionValues[?(@.conditionId=='sc-access-window' && @.parameterName=='accessUntil')].parameterValue",
      "operator": "LessThan",
      "rightOperand": "$.validUntil",
      "valueType": "date",
      "severity": "blocking"
    }
  ],
