        "type": "CLAUSE",
        "title": "Availability Objective",
        "text": "Monthly uptime must be at least 99.95 percent, measured over P1M.",
        "conditionIds": [
          "sc-uptime"
        ],
        "version": 1,
        "contentHash": "sha256:clause-availability-v1"
      },
      {
        "blockId": "clause-access-policy",
        "type": "CLAUSE",
        "title": "Access Policy",
        "text": "Access is limited to organizations located in DE until 2027-05-30.",
