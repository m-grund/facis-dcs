{
  "@context": "https://w3id.org/facis/dcs/context/v1",
  "@id": "did:web:dcs.example:template:sla-api-access-v1",
  "@type": "ContractTemplate",
  "did": "did:web:dcs.example:template:sla-api-access-v1",
  "uuid": "urn:uuid:5c6152f8-f54d-4474-a58c-1fd3f651fe0d",
  "documentNumber": "FACIS-SLA-API-ACCESS",
  "templateVersion": 1,
  "schemaVersion": "v1",
  "semanticProfile": {
    "name": "FACIS DCS Semantic Contract Profile",
    "version": "v1",
    "context": "https://w3id.org/facis/dcs/context/v1",
    "ontology": "https://w3id.org/facis/dcs/ontology/v1",
    "shapes": "https://w3id.org/facis/dcs/shapes/v1"
  },
  "name": "API Access SLA Template",
  "description": "Reusable SLA template for controlled API access with uptime, temporal access, country, and credential constraints.",
  "createdAt": "2026-05-21T10:00:00Z",
  "updatedAt": "2026-05-21T10:00:00Z",
  "template_data": {
    "templateDataVersion": 1,
    "documentOutline": [
      {
        "blockId": "section-root",
        "isRoot": true,
        "children": [
          "section-parties",
          "clause-service-scope",
          "clause-availability",
          "clause-access-policy",
          "clause-remedy"
        ]
      }
    ],
    "documentBlocks": [
      {
        "blockId": "section-parties",
        "type": "SECTION",
        "title": "Parties",
        "text": "The service provider and customer are identified by verifiable organization credentials."
      },
      {
        "blockId": "clause-service-scope",
        "type": "CLAUSE",
        "title": "Service Scope",
        "text": "Provider grants customer access to {{sc-service.serviceName}} at {{sc-service.serviceEndpoint}}.",
        "conditionIds": [
          "sc-service"
        ],
        "version": 1
      },
      {
        "blockId": "clause-availability",
        "type": "CLAUSE",
        "title": "Availability Objective",
        "text": "Monthly uptime must be at least {{sc-uptime.uptimePercentage}} percent, measured over {{sc-uptime.measurementWindow}}.",
        "conditionIds": [
          "sc-uptime"
        ],
        "version": 1
      },
      {
        "blockId": "clause-access-policy",
        "type": "CLAUSE",
        "title": "Access Policy",
        "text": "Access is limited to organizations located in {{sc-country.organizationCountry}} until {{sc-access-window.accessUntil}}.",
        "conditionIds": [
          "sc-country",
          "sc-access-window"
        ],
        "version": 1
      },
      {
        "blockId": "clause-remedy",
        "type": "CLAUSE",
        "title": "Remedy",
        "text": "If the uptime SLO is missed and no exclusion event applies, the customer may claim a service credit of {{sc-remedy.creditPercentage}} percent.",
        "conditionIds": [
          "sc-remedy"
        ],
        "version": 1
      }
    ],
    "semanticConditions": [
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-service",
        "conditionName": "Service identity",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "serviceName",
            "type": "string",
            "isRequired": true,
            "semanticMeaning": "https://w3id.org/facis/dcs/ontology/v1#Service",
            "uiMetadata": {
              "label": "Service name",
              "input": "text"
            },
            "operators": [],
            "value": null
          },
          {
            "parameterName": "serviceEndpoint",
            "type": "string",
            "isRequired": true,
            "uiMetadata": {
              "label": "Service endpoint",
              "input": "url"
            },
            "operators": [
              {
                "operate": "matchesRegex",
                "targets": [
                  "^https://"
                ]
              }
            ],
            "value": null
          }
        ]
      },
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-uptime",
        "conditionName": "Minimum monthly uptime",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "uptimePercentage",
            "type": "decimal",
            "isRequired": true,
            "defaultValue": 99.95,
            "semanticMeaning": "https://w3id.org/facis/dcs/ontology/v1#SLO",
            "uiMetadata": {
              "label": "Monthly uptime",
              "input": "number",
              "suffix": "%"
            },
            "operators": [
              {
                "operate": "greaterThanOrEqual",
                "targets": [
                  "99.95"
                ]
              }
            ],
            "value": null
          },
          {
            "parameterName": "measurementWindow",
            "type": "string",
            "isRequired": true,
            "defaultValue": "P1M",
            "uiMetadata": {
              "label": "Measurement window",
              "input": "select"
            },
            "operators": [
              {
                "operate": "equal",
                "targets": [
                  "P1M"
                ]
              }
            ],
            "value": null
          }
        ]
      },
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-country",
        "conditionName": "Customer country",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "organizationCountry",
            "type": "string",
            "isRequired": true,
            "defaultValue": "DE",
            "semanticMeaning": "https://schema.org/addressCountry",
            "uiMetadata": {
              "label": "Organization country",
              "input": "country"
            },
            "operators": [
              {
                "operate": "equal",
                "targets": [
                  "DE"
                ]
              }
            ],
            "value": null
          }
        ]
      },
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-access-window",
        "conditionName": "Access window",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "accessUntil",
            "type": "date",
            "isRequired": true,
            "semanticMeaning": "https://w3id.org/facis/dcs/ontology/v1#validUntil",
            "uiMetadata": {
              "label": "Access until",
              "input": "date"
            },
            "operators": [
              {
                "operate": "lessThanOrEqual",
                "targets": [
                  "{{contractEndDate}}"
                ]
              }
            ],
            "value": null
          }
        ]
      },
      {
        "@type": "SemanticCondition",
        "conditionId": "sc-remedy",
        "conditionName": "Service credit",
        "schemaVersion": "v1",
        "parameters": [
          {
            "parameterName": "creditPercentage",
            "type": "decimal",
            "isRequired": true,
            "defaultValue": 10,
            "uiMetadata": {
              "label": "Service credit",
              "input": "number",
              "suffix": "%"
            },
            "operators": [
              {
                "operate": "between",
                "targets": [
                  "0",
                  "100"
                ]
              }
            ],
            "value": null
          }
        ]
      }
    ],
    "templateVariables": [
      {
        "@type": "TemplateVariable",
        "parameterName": "contractEndDate",
        "parameterType": "date",
        "required": true,
        "semanticMeaning": "https://w3id.org/facis/dcs/ontology/v1#validUntil",
        "uiMetadata": {
          "label": "Contract end date",
          "input": "date"
        }
      }
    ],
    "placeholderBindings": [
      {
        "@type": "PlaceholderBinding",
        "placeholder": "{{sc-uptime.uptimePercentage}}",
        "boundToCondition": "sc-uptime",
        "boundToParameter": "uptimePercentage",
        "blockId": "clause-availability"
      },
      {
        "@type": "PlaceholderBinding",
        "placeholder": "{{sc-access-window.accessUntil}}",
        "boundToCondition": "sc-access-window",
        "boundToParameter": "accessUntil",
        "blockId": "clause-access-policy"
      }
    ],
    "customMetaData": [
      {
        "name": "contractType",
        "value": "SLA"
      },
      {
        "name": "jurisdiction",
        "value": "DE"
      }
    ]
  },
  "sla": {
    "@type": "SLAAgreement",
    "service": {
      "@type": "Service",
      "identifier": "showtimes-api",
      "name": "Showtimes API",
      "targetEndpoint": "https://api.example.org/showtimes"
    },
    "slos": [
      {
        "@type": "SLO",
        "identifier": "slo-uptime-monthly",
        "name": "Monthly API uptime",
        "sli": {
          "@type": "SLI",
          "metric": {
            "@type": "MeasurementMetric",
            "metricId": "uptime",
            "name": "HTTP availability percentage"
          }
        },
        "operator": "GreaterThanOrEqual",
        "targetValue": 99.95,
        "measurementRules": [
          {
            "@type": "MeasurementRule",
            "identifier": "mr-uptime-monthly",
            "measurementWindow": "P1M",
            "leftOperand": "$.metrics.uptime",
            "operator": "GreaterThanOrEqual",
            "rightOperand": 99.95,
            "valueType": "decimal"
          }
        ],
        "remedies": [
          {
            "@type": "ServiceCredit",
            "identifier": "credit-uptime-breach",
            "creditPercentage": 10,
            "description": "Ten percent monthly service credit if uptime is below target and no exclusion event applies."
          }
        ]
      }
    ],
    "claimPolicy": {
      "@type": "ClaimPolicy",
      "identifier": "claim-policy-standard",
      "description": "Customer must submit claim within 30 days after the end of the affected measurement window.",
      "allowedClaimWindow": "P30D"
    },
    "exclusionEvents": [
      {
        "@type": "ExclusionEvent",
        "identifier": "planned-maintenance",
        "name": "Planned maintenance",
        "description": "Announced maintenance windows are excluded from uptime calculation."
      },
      {
        "@type": "ExclusionEvent",
        "identifier": "force-majeure",
        "name": "Force majeure",
        "description": "Force majeure events are excluded from remedy calculation."
      }
    ]
  },
  "semanticRules": [
    {
      "@type": "ThresholdRule",
      "ruleId": "rule-uptime-minimum",
      "leftOperand": "$.sla.slos[?(@.identifier=='slo-uptime-monthly')].targetValue",
      "operator": "GreaterThanOrEqual",
      "rightOperand": 99.95,
      "valueType": "decimal",
      "severity": "blocking"
    },
    {
      "@type": "SemanticRule",
      "ruleId": "rule-organization-country-de",
      "leftOperand": "$.parties[?(@.role=='customer')].country",
      "operator": "Equals",
      "rightOperand": "DE",
      "valueType": "string",
      "severity": "blocking"
    },
    {
      "@type": "DateConstraintRule",
      "ruleId": "rule-access-before-contract-end",
      "leftOperand": "$.contractData.semanticConditionValues[?(@.conditionId=='sc-access-window' && @.parameterName=='accessUntil')].parameterValue",
      "operator": "LessThan",
      "rightOperand": "$.validUntil",
      "valueType": "date",
      "severity": "blocking"
    }
  ],
  "provenance": [
    {
      "@type": "ProvenanceEvent",
      "eventId": "urn:uuid:02e1e3a4-b1f0-45a2-bdd9-ac4280d3a1a7",
      "eventType": "template.created",
      "actor": "did:web:dcs.example:users:template-manager",
      "actorRole": "TemplateManager",
      "occurredAt": "2026-05-21T10:00:00Z",
      "contentHash": "sha256:template-source-hash"
    }
  ]
}
