{
  "policySetId": "facis.dcs.template.audit",
  "version": "v1",
  "ontology": "https://w3id.org/facis/dcs/ontology/v1",
  "description": "Example policy rules for auditing finished FACIS DCS contract templates against the shared ontology and SRS validation expectations.",
  "rules": [
    {
      "id": "FACIS-TPL-STRUCT-001",
      "title": "Template uses canonical JSON-LD document structure",
      "severity": "error",
      "builtin": "canonical_document_structure",
      "ontologyTerm": "dcs:DocumentStructure",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"]
    },
    {
      "id": "FACIS-TPL-DATA-001",
      "title": "Template declares contract data requirements",
      "severity": "error",
      "builtin": "canonical_contract_data",
      "ontologyTerm": "dcs:DataRequirement",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"]
    },
    {
      "id": "FACIS-TPL-POLICY-001",
      "title": "Template policies reference declared contract data fields",
      "severity": "error",
      "builtin": "canonical_policy_operands",
      "ontologyTerm": "odrl:Constraint",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"]
    },
    {
      "id": "FACIS-COMP-STRUCT-001",
      "title": "Component document structure is internally consistent",
      "severity": "error",
      "builtin": "component_document_structure_integrity",
      "ontologyTerm": "dcs:DocumentStructure",
      "appliesToTemplateTypes": ["COMPONENT"]
    },
    {
      "id": "FACIS-COMP-DATA-001",
      "title": "Component contract data declarations are internally consistent",
      "severity": "error",
      "builtin": "component_contract_data_integrity",
      "ontologyTerm": "dcs:DataRequirement",
      "appliesToTemplateTypes": ["COMPONENT"]
    },
    {
      "id": "FACIS-COMP-POLICY-001",
      "title": "Component policies reference declared component data fields",
      "severity": "error",
      "builtin": "component_policy_operand_integrity",
      "ontologyTerm": "odrl:Constraint",
      "appliesToTemplateTypes": ["COMPONENT"]
    },
    {
      "id": "FACIS-TPL-LIFECYCLE-001",
      "title": "Audited finished template is approved or registered",
      "severity": "info",
      "builtin": "finished_template_state",
      "ontologyTerm": "dcs:LifecycleState",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"],
      "parameters": {
        "states": [
          "APPROVED",
          "REGISTERED"
        ]
      }
    },
    {
      "id": "FACIS-TPL-CLAUSE-001",
      "title": "Finished template contains at least one clause bound to contract data",
      "severity": "error",
      "builtin": "finished_template_has_clause_semantics",
      "ontologyTerm": "dcs:Clause",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"]
    },
    {
      "id": "FACIS-TPL-DOMAIN-001",
      "title": "Template semantic parameters use canonical domain fields",
      "severity": "error",
      "builtin": "canonical_domain_fields",
      "ontologyTerm": "dcs:DomainField",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE", "COMPONENT"]
    },
    {
      "id": "FACIS-TPL-CONSTRAINT-001",
      "title": "Constrained semantic parameters carry ontology constraints",
      "severity": "error",
      "builtin": "constrained_parameters_use_value_constraint",
      "ontologyTerm": "dcs:ValueConstraint",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE", "COMPONENT"]
    },
    {
      "id": "FACIS-TPL-LEGAL-001",
      "title": "Finished template exposes jurisdiction for policy checks",
      "severity": "warning",
      "builtin": "required_domain_fields",
      "ontologyTerm": "dcst:field-contract-jurisdiction",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"],
      "parameters": {
        "fieldIris": [
          "https://w3id.org/facis/dcs/taxonomy/v1#field-contract-jurisdiction"
        ]
      }
    },
    {
      "id": "FACIS-TPL-PARTY-001",
      "title": "Finished template exposes company country as ISO 3166-1 alpha-3",
      "severity": "warning",
      "builtin": "required_domain_fields",
      "ontologyTerm": "dcst:field-company-location-country",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"],
      "parameters": {
        "fieldIris": [
          "https://w3id.org/facis/dcs/taxonomy/v1#field-company-location-country"
        ]
      }
    },
    {
      "id": "FACIS-TPL-SIGN-001",
      "title": "Finished template declares required signature level",
      "severity": "warning",
      "builtin": "required_domain_fields",
      "ontologyTerm": "dcst:field-signature-requiredLevel",
      "appliesToTemplateTypes": ["CONTRACT_TEMPLATE"],
      "parameters": {
        "fieldIris": [
          "https://w3id.org/facis/dcs/taxonomy/v1#field-signature-requiredLevel"
        ]
      }
    },
    {
      "id": "FACIS-TPL-AUDIT-001",
      "title": "Template declares audit-relevant policy and semantic metadata",
      "severity": "warning",
      "builtin": "audit_metadata_complete",
      "ontologyTerm": "dcs:AuditEvent"
    }
  ]
}
