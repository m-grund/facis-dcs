
# Backend endpoint pdf-core calls to sign COSE Sig_structure bytes with the
# PKCS#11 dcs-c2pa key (DCS-IR-HI-01). pdf-core holds no key material.
DCS_PDF_CORE_C2PA_SIGNING_ENDPOINT=http://localhost:8991/api/internal/c2pa/sign
# Dev CA leaf whose public key matches the dcs-c2pa token key, embedded as the
# COSE x5chain. Provisioned by scripts/c2pa-cert-provision.sh.
DCS_PDF_CORE_C2PA_X5CHAIN_PEM_FILE=certs/dev/c2pa-x5chain-8991.pem

# Ontology base URL — sets dcsCoreIRI and the @vocab in the served context document.
# Must match PDF_CORE_CONTEXT_IRI in the backend .env.dev so the in-process
# context loader intercepts the exact IRI the backend embeds in JSON-LD envelopes.
DCS_PDF_CORE_ONTOLOGY_BASE_URL=http://localhost:8080
