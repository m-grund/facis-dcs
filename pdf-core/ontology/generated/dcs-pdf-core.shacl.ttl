@prefix dcs_pdf_core: <http://127.0.0.1:8080/ontology/dcs-pdf-core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcs_pdf_core:Document a sh:NodeShape ;
    rdfs:comment "A deterministic PDF/A-3a document produced by the dcs-pdf-core compiler. Acts as the root node of the semantic payload graph. The title and sections slots drive the human-readable PDF layout. Any additional JSON-LD properties or namespaces not defined in this ontology are preserved in the embedded JSON-LD attachment and not rendered in the PDF." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcs_pdf_core:SignatureField ;
            sh:description "Ordered list of visible signature field definitions rendered as AcroForm signature widgets on a dedicated final page." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path dcs_pdf_core:signatureFields ],
        [ sh:class dcs_pdf_core:Section ;
            sh:description "Ordered list of headed sections constituting the document body. Each section carries a heading and an array of clauses. A top-level clauses array (without sections) is also accepted and treated as a single anonymous section." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path dcs_pdf_core:sections ],
        [ sh:datatype xsd:string ;
            sh:description "Canonical document title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs_pdf_core:title ] ;
    sh:targetClass dcs_pdf_core:Document .

dcs_pdf_core:Clause a sh:NodeShape ;
    rdfs:comment "A structured clause entry containing mixed-content inline segments. The content list may include prose strings and JSON-LD node objects such as ontology references, external links, or typed literal values." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Ordered mixed-content inline segments for a clause. Entries may be plain text or JSON-LD node objects (e.g. @id links, schema:url links, typed values)." ;
            sh:minCount 1 ;
            sh:or ( [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] [ sh:class dcs_pdf_core:ContentNode ] ) ;
            sh:order 0 ;
            sh:path dcs_pdf_core:content ] ;
    sh:targetClass dcs_pdf_core:Clause .

dcs_pdf_core:ContentNode a sh:NodeShape ;
    rdfs:comment "Generic JSON-LD node object used inside clause content arrays for ontology references, external links, and typed literals." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass dcs_pdf_core:ContentNode .

dcs_pdf_core:SignatureField a sh:NodeShape ;
    rdfs:comment "A visible signature field placeholder rendered in the compiled PDF as an AcroForm /Sig widget annotation. Field names are stable anchors used by external PAdES signing tools." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Stable PDF field name used in /T for a signature widget." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs_pdf_core:name ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label drawn in the signature field appearance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcs_pdf_core:label ] ;
    sh:targetClass dcs_pdf_core:SignatureField .

dcs_pdf_core:Section a sh:NodeShape ;
    rdfs:comment "A headed section within a document, analogous to a numbered article or clause block in a legal contract. The heading is rendered as a PDF heading structural element and added to the PDF outline (bookmarks). Each clause in the section is rendered as a tagged paragraph. Sections may contain nested subsections to arbitrary depth." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable section heading rendered as a PDF heading structural element and added to the PDF outline bookmarks tree. The heading level (H1, H2, H3, …) is determined by nesting depth." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcs_pdf_core:heading ],
        [ sh:description "Ordered list of clause content items within a section. Each entry is either a plain string (prose) or a JSON-LD node object. Node objects dispatch on key presence: @id renders as an ontology reference with a glossary link; schema:url renders as an external hyperlink; @value/@type renders as a typed literal. Mixed-content arrays (where a clause is itself an array of these items) are supported for inline rich text." ;
            sh:minCount 1 ;
            sh:or ( [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] [ sh:class dcs_pdf_core:Clause ] ) ;
            sh:order 1 ;
            sh:path dcs_pdf_core:clauses ],
        [ sh:class dcs_pdf_core:Section ;
            sh:description "Ordered list of nested subsections. Each subsection is itself a Section and may contain further subsections, enabling arbitrary nesting depth. The heading level of each subsection is determined by its depth in the nesting hierarchy." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path dcs_pdf_core:subsections ] ;
    sh:targetClass dcs_pdf_core:Section .


