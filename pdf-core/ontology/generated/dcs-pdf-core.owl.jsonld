  },
  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#clauses",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "clauses"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "_:nf9c7b2c67cb0457d85384d425a79a49ab8"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Ordered list of clause content items within a section. Each entry is either a plain string (prose) or a JSON-LD node object. Node objects dispatch on key presence: @id renders as an ontology reference with a glossary link; schema:url renders as an external hyperlink; @value/@type renders as a typed literal. Mixed-content arrays (where a clause is itself an array of these items) are supported for inline rich text."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
      }
    ]
  },
  {
