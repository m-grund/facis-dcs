      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Human-readable section heading rendered as a PDF heading structural element and added to the PDF outline bookmarks tree. The heading level (H1, H2, H3, …) is determined by nesting depth."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
      }
    ]
  },
  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#sections",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "sections"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#Section"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Ordered list of headed sections constituting the document body. Each section carries a heading and an array of clauses. A top-level clauses array (without sections) is also accepted and treated as a single anonymous section."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
