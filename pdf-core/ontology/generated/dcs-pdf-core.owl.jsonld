      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A headed section within a document, analogous to a numbered article or clause block in a legal contract. The heading is rendered as a PDF heading structural element and added to the PDF outline (bookmarks). Each clause in the section is rendered as a tagged paragraph. Sections may contain nested subsections to arbitrary depth."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
