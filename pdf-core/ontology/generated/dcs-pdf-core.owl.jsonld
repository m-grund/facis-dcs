  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#clauses",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "clauses"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "_:n834d424060254c8b81b2363108f6d70bb8"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Ordered list of clause content items within a section. Each entry is either a plain string (prose) or a JSON-LD node object. Node objects dispatch on key presence: @id renders as an ontology reference with a glossary link; schema:url renders as an external hyperlink; @value/@type renders as a typed literal. Mixed-content arrays (where a clause is itself an array of these items) are supported for inline rich text."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
      }
    ]
  },
  {
    "@id": "_:n834d424060254c8b81b2363108f6d70bb8",
    "http://www.w3.org/2002/07/owl#unionOf": [
      {
        "@list": [
          {
            "@id": "http://www.w3.org/2001/XMLSchema#string"
          },
          {
            "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#Clause"
          }
        ]
      }
    ]
  },
  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#subsections",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "subsections"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#Section"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Ordered list of nested subsections. Each subsection is itself a Section and may contain further subsections, enabling arbitrary nesting depth. The heading level of each subsection is determined by its depth in the nesting hierarchy."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
      }
    ]
  },
  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#Clause",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clause"
      }
    ],
