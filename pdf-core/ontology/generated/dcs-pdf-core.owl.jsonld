  {
    "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core.owl.ttl",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@value": "dcs-pdf-core Structural Document Ontology"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "dcs_pdf_core"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Base ontology for the dcs-pdf-core deterministic PDF/A-3a compiler. Defines structural document primitives used to drive human-readable layout generation from an embedded JSON-LD data twin. Content items within clauses are expressed using standard JSON-LD patterns: plain strings for prose, @id for ontology references, schema:url for external links, and @value/@type for typed literals. Additional namespaced properties not defined in this ontology (e.g. ODRL policies, provenance graphs) are carried through in the embedded JSON-LD attachment unchanged and are not rendered in the human-readable PDF output."
      }
    ]
  }
]