        "@id": "_:n834d424060254c8b81b2363108f6d70bb12"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A structured clause entry containing mixed-content inline segments. The content list may include prose strings and JSON-LD node objects such as ontology references, external links, or typed literal values."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core#Clause"
