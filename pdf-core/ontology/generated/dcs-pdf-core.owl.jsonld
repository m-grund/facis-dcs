    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A deterministic PDF/A-3a document produced by the dcs-pdf-core compiler. Acts as the root node of the semantic payload graph. The title and sections slots drive the human-readable PDF layout. Any additional JSON-LD properties or namespaces not defined in this ontology are preserved in the embedded JSON-LD attachment and not rendered in the PDF."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
