      {
        "@id": "_:nf9c7b2c67cb0457d85384d425a79a49ab11"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Ordered mixed-content inline segments for a clause. Entries may be plain text or JSON-LD node objects (e.g. @id links, schema:url links, typed values)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "http://127.0.0.1:8080/ontology/dcs-pdf-core"
      }
