# Backend dev environment – matches the NodePort services from values.dev.yml.
# Usage (from project root):
#   make dev
#
# This will setup Helm, fetch cert-chain from K8s, copy this file to .env, and run air.

DATABASE_URL="host=localhost port=30432 user=dcs password=dcs dbname=dcs sslmode=disable"

HYDRA_ISSUER_URL=http://localhost:30444
HYDRA_CLIENT_ID=dcs-client
HYDRA_CLIENT_SECRET=dcs-secret
HYDRA_REDIRECT_URI=http://localhost:5173/api/auth/callback
HYDRA_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/api/auth/logout-complete
HYDRA_ADMIN_URL=http://localhost:30085

NATS_URL=nats://localhost:30422

DCS_ISSUER=localhost

DCS_API_PATH=/api
DCS_UI_PATH=/ui/

OID4VP_TRUST_DATA_PATH=config/oid4vp/trust.dev.json
OID4VP_DID_RESOLVER_URL=https://dev.uniresolver.io

FC_KEYCLOAK_REALM_URL=http://localhost:30080/realms/gaia-x
FEDERATED_CATALOGUE_API_URL=http://localhost:30081
FEDERATED_CATALOGUE_CLIENT_ID=dcs-fc-client
FEDERATED_CATALOGUE_CLIENT_SECRET=dcs-fc-client-secret
ORCE_ARCHIVE_NOTARY_URL=http://localhost:30180/archive/notary
ORCE_ARCHIVE_AUDIT_LOG_URL=http://localhost:30180/archive-audit-events.jsonl
ORCE_ARCHIVE_AUDIT_LOG_BEARER_TOKEN=dev-archive-audit-token

IPFS_TENANT_BASE_URL=http://localhost:30481/v1/tenants/tenant_space
IPFS_MFS_BASE_URL=http://localhost:30501

CRYPTO_PROVIDER_URL=http://localhost:30808
CRYPTO_PROVIDER_NAMESPACE=transit
CRYPTO_PROVIDER_KEY=dcs-signing-key-p256
CRYPTO_PROVIDER_VC_KEY=dcs-vc-signing-key
CRYPTO_PROVIDER_VC_SIGNATURE_TYPE=ed25519signature2020
CRYPTO_PROVIDER_CERT_CHAIN_FILE=certs/dev/chain.pem

STATUSLIST_SERVICE_URL=http://localhost:30821

ISSUER_DID=did:web:localhost

TSA_URL=http://localhost:30180/tsa/