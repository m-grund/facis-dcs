# Backend dev environment – matches the NodePort services from values.dev.yml.
# Usage (from project root):
#   make dev
#
# This will setup Helm, fetch cert-chain from K8s, copy this file to .env, and run air.

DCS_DEBUG_EVENTING=false

DATABASE_URL="host=localhost port=30432 user=dcs password=dcs dbname=dcs sslmode=disable"

HYDRA_PUBLIC_ISSUER_URL=http://localhost:5173
HYDRA_INTERNAL_ISSUER_URL=http://localhost:30444
HYDRA_CLIENT_ID=dcs-client
HYDRA_CLIENT_SECRET=dcs-secret
HYDRA_REDIRECT_URI=http://localhost:5173/api/auth/callback
HYDRA_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/api/auth/logout-complete
HYDRA_ADMIN_URL=http://localhost:30085

NATS_URL=nats://localhost:30422

DCS_DID=./certs/dev/did-8991.json
DCS_FORCE_EIDAS_CERT=false

# PKCS#11 token (SoftHSM2 in dev) holding every private key (DCS-IR-HI-01).
# Separate token dir per instance; dev-stack.sh injects the absolute
# SOFTHSM2_CONF path after provisioning the token.
PKCS11_MODULE_PATH=/usr/lib/softhsm/libsofthsm2.so
PKCS11_TOKEN_LABEL=dcs
PKCS11_PIN=1234
DCS_HSM_KEY_DID=dcs-did
DCS_HSM_KEY_VC=dcs-vc
DCS_HSM_KEY_JAR=dcs-oid4vp-jar
DCS_HSM_KEY_PADES=dcs-contract-pades
DCS_HSM_KEY_C2PA=dcs-c2pa

DCS_BACKEND_PORT=8991

DCS_API_PATH=/api
DCS_UI_PATH=/ui/
DCS_PUBLIC_BASE_URL=http://localhost:5173/api

OID4VP_TRUST_DATA_PATH=config/oid4vp/trust.dev.json
OID4VP_STATUSLIST_SKIP_JWS_VERIFY=true
AUTH_INSECURE_COOKIES=true
OID4VP_DID_RESOLVER_URL=https://dev.uniresolver.io

FC_KEYCLOAK_REALM_URL=http://localhost:30080/realms/gaia-x
FEDERATED_CATALOGUE_API_URL=http://localhost:30081
FEDERATED_CATALOGUE_CLIENT_ID=dcs-fc-client
FEDERATED_CATALOGUE_CLIENT_SECRET=dcs-fc-client-secret
ORCE_ARCHIVE_NOTARY_URL=http://localhost:30180/archive/notary
ORCE_ARCHIVE_AUDIT_LOG_URL=http://localhost:30180/archive-audit-events.jsonl
ORCE_ARCHIVE_AUDIT_LOG_BEARER_TOKEN=dev-archive-audit-token

IPFS_TENANT_BASE_URL=http://localhost:30481/v1/tenants/tenant_space
IPFS_MFS_BASE_URL=http://localhost:30501

# This instance's own DID, used as the VC issuer for lifecycle credentials
# (DCS-OR-C2PA-004). Symmetric with .env.dev2's ISSUER_DID (port 8992).
ISSUER_DID=did:web:localhost%3A8991

STATUSLIST_SERVICE_URL=http://localhost:30821

PDF_CORE_URL=http://localhost:8080

# Public base URL of this DCS instance. Used to build the C2PA remote-manifest
# URL (DCS_PUBLIC_URL + /c2pa/manifest/{contract_did}) embedded as the C2PA
# claim's remote_manifests field (DCS-OR-C2PA-008 AC3).
DCS_PUBLIC_URL=http://localhost:8991/api

# JSON-LD @context IRI for the pdf-core ontology, embedded in every contract/template envelope.
# In co-deployment, points at the pdf-core context endpoint.
# Swap to a registered w3id IRI once available.
PDF_CORE_CONTEXT_IRI=http://localhost:8080/ontology/dcs-pdf-core

# Local-only WSL relay workaround (regressed back to the real freetsa.org
# NodePort path at some point — restored here): dcs-orce's /tsa/:hash flow
# proxies to the real https://freetsa.org/tsr, which is slow/rate-limited
# under repeated BDD-driven calls and produced sporadic
# "context deadline exceeded" timeouts during approve/archive. backend/tsa-relay.py
# is a local, deterministic self-signed TSA stub both instances point at
# instead (see .env.dev2's identical override for the twin comment).
TSA_URL=http://localhost:9091/tsa/

# Two-instance inter-org setup (features/17_peer_trust): seed instance B's
# DID as a trusted peer at startup, symmetric with .env.dev2's
# DCS_TRUSTED_PEERS.
DCS_TRUSTED_PEERS=did:web:localhost%3A8992
