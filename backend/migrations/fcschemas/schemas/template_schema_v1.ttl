@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix dcs-template: <https://argo.asd-stack.eu/facis/dcs-semantic/template/v1#> .
@prefix dcs-template-data: <https://argo.asd-stack.eu/facis/dcs-semantic/template-data/v1#> .


<https://argo.asd-stack.eu/facis/dcs-semantic/template/v1>
  a owl:Ontology ;
  rdfs:label "FACIS DCS Template Ontology" ;
  rdfs:comment "Ontology for contract template." .

<https://argo.asd-stack.eu/facis/dcs-semantic/template-data/v1>
  a owl:Ontology ;
  rdfs:label "FACIS DCS Template Data Ontology" ;
  rdfs:comment "Ontology for contract template data." .

