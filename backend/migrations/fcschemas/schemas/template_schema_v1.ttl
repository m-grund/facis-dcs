#### =================================================================

### 1. Core template classes
dcs-template:ContractTemplate a rdfs:Class ;
  rdfs:label "Contract Template" .

dcs-template-data:TemplateData a rdfs:Class ;
  rdfs:label "Template Data" ;
  rdfs:comment "Corresponds to the contract_templates table 'template_data' field and stores the full JSON content." .

### 2. Template Properties
dcs-template:did a rdf:Property ;
  rdfs:label "DID of the contract template" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:documentNumber a rdf:Property ;
  rdfs:label "Document Number" ;
  rdfs:comment "Identifier shared/ by all versions of the same contract template." ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:version a rdf:Property ;
  rdfs:label "Version" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:integer .

dcs-template:schemaVersion a rdf:Property ;
  rdfs:label "Schema Version" ;
  rdfs:comment "Version of the template schema used by this contract template." ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:integer .

dcs-template:templateType a rdf:Property ;
  rdfs:label "The Type of the template" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:name a rdf:Property ;
  rdfs:label "The name of the template" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:description a rdf:Property ;
  rdfs:label "A description for that template" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:participantId a rdf:Property ;
  rdfs:label "Participant ID" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:publisher a rdf:Property ;
  rdfs:label "Publisher" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

dcs-template:createdAt a rdf:Property ;
  rdfs:label "The timestamp when the contract template was created" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:dateTime .

dcs-template:updatedAt a rdf:Property ;
  rdfs:label "The timestamp when the contract temlate was updated" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:dateTime .

dcs-template:templateData a rdf:Property ;
  rdfs:label "Template data of the contract template" ;
  rdfs:domain dcs-template:ContractTemplate .

dcs-template:templateDataJSON a rdf:Property ;
  rdfs:label "Template data JSON" ;
  rdfs:domain dcs-template:ContractTemplate ;
  rdfs:range xsd:string .

### 3. Template Shape

dcs-template:ContractTemplateShape
  a sh:NodeShape ;
  sh:targetClass dcs-template:ContractTemplate ;

  sh:property [
    sh:path dcs-template:did ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:documentNumber ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:version ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 0 ;
  ] ;

  sh:property [
    sh:path dcs-template:schemaVersion ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:templateType ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:description ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
      sh:path dcs-template:participantId ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
  ] ;

  sh:property [
      sh:path dcs-template:publisher ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:createdAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path dcs-template:updatedAt ;
    sh:datatype xsd:dateTime ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template:templateData ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:node dcs-template:TemplateDataShape ;
  ] ;
  sh:property [
    sh:path dcs-template:templateDataJSON ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

### 4. TemplateData Properties
dcs-template-data:template_data a rdf:Property ;
  rdfs:label "Template data" .

dcs-template-data:type a rdf:Property ;
  rdfs:label "Type" .

dcs-template-data:documentBlocks a rdf:Property ;
  rdfs:label "Document blocks" .

dcs-template-data:blockId a rdf:Property ;
  rdfs:label "Block ID" .

dcs-template-data:text a rdf:Property ;
  rdfs:label "Block text" .

dcs-template-data:title a rdf:Property ;
  rdfs:label "Block title" .

dcs-template-data:templateId a rdf:Property ;
  rdfs:label "Template ID" .

dcs-template-data:version a rdf:Property ;
  rdfs:label "Version" .

dcs-template-data:document_number a rdf:Property ;
  rdfs:label "Document number" .

dcs-template-data:name a rdf:Property ;
  rdfs:label "Name" .

dcs-template-data:value a rdf:Property ;
  rdfs:label "Value" .

dcs-template-data:did a rdf:Property ;
  rdfs:label "DID" .

dcs-template-data:conditionIds a rdf:Property ;
  rdfs:label "Condition IDs" .

dcs-template-data:templateDataVersion a rdf:Property ;
  rdfs:label "Template data version" .

### 4.1. DocumentOutline Properties
dcs-template-data:documentOutline a rdf:Property ;
  rdfs:label "Document outline" .

dcs-template-data:isRoot a rdf:Property ;
  rdfs:label "Is root block" .

dcs-template-data:children a rdf:Property ;
  rdfs:label "Child block IDs" .

### 4.2. SemanticConditions Properties
dcs-template-data:semanticConditions a rdf:Property ;
  rdfs:label "Semantic conditions" .

dcs-template-data:parameters a rdf:Property ;
  rdfs:label "Semantic condition parameters" .

dcs-template-data:conditionId a rdf:Property ;
  rdfs:label "Condition ID" .

dcs-template-data:conditionName a rdf:Property ;
  rdfs:label "Condition name" .

dcs-template-data:schemaVersion a rdf:Property ;
  rdfs:label "Schema version" .

dcs-template-data:parameterName a rdf:Property ;
  rdfs:label "Parameter name" .

dcs-template-data:isRequired a rdf:Property ;
  rdfs:label "Is required" .

dcs-template-data:operators a rdf:Property ;
  rdfs:label "Operators" .

dcs-template-data:operate a rdf:Property ;
  rdfs:label "Operator type" .

dcs-template-data:targets a rdf:Property ;
  rdfs:label "Operator targets" .

### 4.3. CustomMetaData Properties
dcs-template-data:customMetaData a rdf:Property ;
  rdfs:label "Custom metadata" .

### 4.4. SubTemplateSnapshots Properties
dcs-template-data:subTemplateSnapshots a rdf:Property ;
  rdfs:label "Sub-template snapshots" .

### 5. TemplateData Shape
dcs-template:TemplateDataShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:documentOutline ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:DocumentOutlineBlockShape ;
  ] ;
  sh:property [
    sh:path dcs-template-data:semanticConditions ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:SemanticConditionShape ;
  ] ;
  sh:property [
    sh:path dcs-template-data:documentBlocks ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:DocumentBlockUnionShape ;
  ] ;
  sh:property [
    sh:path dcs-template-data:customMetaData ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:MetaDataShape ;
  ] ;
  sh:property [
    sh:path dcs-template-data:subTemplateSnapshots ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:SubTemplateSnapshotShape ;
  ] ;
  sh:property [
    sh:path dcs-template-data:templateDataVersion ;
    sh:datatype xsd:integer ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] .

### 5.1. DocumentOutline Shape
dcs-template:DocumentOutlineBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:isRoot ;
    sh:datatype xsd:boolean ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:children ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
  ] .

dcs-template:DocumentBlockUnionShape
  a sh:NodeShape ;
  sh:or (
    dcs-template:SectionBlockShape
    dcs-template:TextBlockShape
    dcs-template:ClauseBlockShape
    dcs-template:ApprovedTemplateBlockShape
    dcs-template:MergedApprovedTemplateBlockShape
  ) .

dcs-template:SectionBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcs-template-data:SECTION ;
  ] ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:title ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] .

dcs-template:TextBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcs-template-data:TEXT ;
  ] ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:title ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] .

dcs-template:ClauseBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcs-template-data:CLAUSE ;
  ] ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:title ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:conditionIds ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] .

dcs-template:ApprovedTemplateBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcs-template-data:APPROVED_TEMPLATE ;
  ] ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:title ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:templateId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:version ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:or (
      [ sh:datatype xsd:integer ]
      [ sh:datatype xsd:double ]
      [ sh:datatype xsd:decimal ]
    ) ;
  ] ;
  sh:property [
    sh:path dcs-template-data:document_number ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

dcs-template:MergedApprovedTemplateBlockShape
  a sh:NodeShape ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue dcs-template-data:MERGED_APPROVED_TEMPLATE ;
  ] ;
  sh:property [
    sh:path dcs-template-data:blockId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:text ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:title ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:templateId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:version ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:or (
      [ sh:datatype xsd:integer ]
      [ sh:datatype xsd:double ]
      [ sh:datatype xsd:decimal ]
    ) ;
  ] ;
  sh:property [
    sh:path dcs-template-data:document_number ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

### 5.2. SemanticConditions Shape
dcs-template:SemanticConditionShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:conditionId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:conditionName ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:schemaVersion ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:parameters ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 1 ;
    sh:node dcs-template:SemanticConditionParameterShape ;
  ] .

dcs-template:SemanticConditionParameterShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:parameterName ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path rdf:type ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( dcs-template-data:date dcs-template-data:string dcs-template-data:integer dcs-template-data:decimal ) ;
  ] ;
  sh:property [
    sh:path dcs-template-data:isRequired ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:operators ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:node dcs-template:SemanticParameterOperatorShape ;
  ] .

dcs-template:SemanticParameterOperatorShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:operate ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in (
      "lessThan"
      "lessThanOrEqual"
      "greaterThan"
      "greaterThanOrEqual"
      "equal"
      "notEqual"
    ) ;
  ] ;
  sh:property [
    sh:path dcs-template-data:targets ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
  ] .

### 5.3. CustomMetaData Shape
dcs-template:MetaDataShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:value ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

### 5.4. SubTemplateSnapshots Shape
dcs-template:SubTemplateSnapshotShape
  a sh:NodeShape ;
  sh:property [
    sh:path dcs-template-data:did ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:document_number ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:version ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:or (
      [ sh:datatype xsd:integer ]
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
  ] ;
  sh:property [
    sh:path dcs-template-data:name ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:description ;
    sh:datatype xsd:string ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dcs-template-data:template_data ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:minCount 0 ;
    sh:maxCount 1 ;
    sh:node dcs-template:TemplateDataShape ;
  ] .