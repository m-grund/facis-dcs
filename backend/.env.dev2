# Backend dev environment – matches the NodePort services from values.dev.yml.
# Usage (from project root):
#   make dev
#
# This will setup Helm, fetch cert-chain from K8s, copy this file to .env, and run air.

DCS_DEBUG_EVENTING=false

DATABASE_URL="host=localhost port=31513 user=dcs password=dcs dbname=dcs sslmode=disable"

HYDRA_PUBLIC_ISSUER_URL=http://localhost:5174
HYDRA_INTERNAL_ISSUER_URL=http://localhost:30555
HYDRA_CLIENT_ID=dcs-client
HYDRA_CLIENT_SECRET=dcs-secret
HYDRA_REDIRECT_URI=http://localhost:5174/api/auth/callback
HYDRA_POST_LOGOUT_REDIRECT_URI=http://localhost:5174/api/auth/logout-complete
HYDRA_ADMIN_URL=http://localhost:31285

NATS_URL=nats://localhost:30122

DCS_DID=./certs/dev/did-8992.json
DCS_PRIVATE_KEY=./certs/dev/signing-8992.key
DCS_FORCE_EIDAS_CERT=false

# Must match this instance's own DID (DCS_DID's "id") — used to derive the
# lifecycle VC's issuer/verificationMethod (see
# backend/internal/cryptoprovider/client.go verificationMethodFor).
ISSUER_DID=did:web:localhost%3A8992

DCS_BACKEND_PORT=8992

DCS_API_PATH=/api
DCS_UI_PATH=/ui/
DCS_PUBLIC_BASE_URL=http://localhost:5174/api

OID4VP_TRUST_DATA_PATH=config/oid4vp/trust.dev.json
OID4VP_DID_RESOLVER_URL=https://dev.uniresolver.io
AUTH_INSECURE_COOKIES=true

VAULT_ADDR=http://localhost:31820
VAULT_TOKEN=root
OID4VP_VERIFIER_SIGNING_VAULT_MOUNT=transit
OID4VP_VERIFIER_SIGNING_VAULT_KEY=dcs-oid4vp-verifier-signing

#FC_KEYCLOAK_REALM_URL=http://localhost:31081/realms/gaia-x
#FEDERATED_CATALOGUE_API_URL=http://localhost:31081
#FEDERATED_CATALOGUE_CLIENT_ID=dcs-fc-client
#FEDERATED_CATALOGUE_CLIENT_SECRET=dcs-fc-client-secret

IPFS_TENANT_BASE_URL=http://localhost:30486/v1/tenants/tenant_space
IPFS_MFS_BASE_URL=http://localhost:31512

CRYPTO_PROVIDER_URL=http://localhost:31818
CRYPTO_PROVIDER_NAMESPACE=transit
CRYPTO_PROVIDER_KEY=dcs-signing-key-p256
CRYPTO_PROVIDER_VC_KEY=dcs-vc-signing-key
CRYPTO_PROVIDER_VC_SIGNATURE_TYPE=ed25519signature2020
# Distinct from instance A's certs/dev/chain.pem so the two dev-stack
# scripts' cert-chain-fetch steps (independent Helm releases "dcs"/"dcs2",
# each with their own dev-cert-chain Job/secret) don't clobber each other.
CRYPTO_PROVIDER_CERT_CHAIN_FILE=certs/dev/chain-b.pem

STATUSLIST_SERVICE_URL=http://localhost:30221

PDF_CORE_URL=http://localhost:8080

# Public base URL of this DCS instance (instance B). Used to build the C2PA
# remote-manifest URL embedded as the claim's remote_manifests field
# (DCS-OR-C2PA-008 AC3).
DCS_PUBLIC_URL=http://localhost:8992/api

# JSON-LD @context IRI for the pdf-core ontology, embedded in every contract/template envelope.
# In co-deployment, points at the pdf-core context endpoint.
# Swap to a registered w3id IRI once available.
PDF_CORE_CONTEXT_IRI=http://localhost:8080/ontology/dcs-pdf-core

# Same local-only WSL relay workaround as instance A's backend/.env (see
# there for why the real TSA_URL — dcs-orce's /tsa/:hash flow, which
# proxies to https://freetsa.org/tsr — is unreachable from the cluster pod
# network): backend/tsa-relay.py is a single shared relay both instances can
# point at.
TSA_URL=http://localhost:9091/tsa/

# Two-instance inter-org demo (Workstream C1-C3, docs/anforderung.md): seed
# instance A's DID as a trusted peer at startup (AC1), symmetric with
# .env.dev1's DCS_TRUSTED_PEERS above.
DCS_TRUSTED_PEERS=did:web:localhost%3A8991
