  dcs:valueSymbol "Kč" .

dcst:constraint-eidas-signature-level a dcs:ValueConstraint ;
  dcs:format "eidas-signature-level" ;
  dcs:allowedValue "SES", "AES", "QES" ;
  rdfs:label "eIDAS Signature Level Constraint"@en .

dcst:constraint-sla-availability-percent a dcs:ValueConstraint ;
  dcs:minInclusive 0 ;
  dcs:maxInclusive 100 ;
  dcs:format "percentage" ;
  rdfs:label "SLA Availability Percentage Constraint"@en .

dcst:constraint-duration-minutes-non-negative a dcs:ValueConstraint ;
  dcs:minInclusive 0 ;
  dcs:format "duration-minutes" ;
  rdfs:label "Non-negative Duration in Minutes Constraint"@en .

dcst:constraint-contract-type a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "frameworkAgreement", "serviceAgreement", "dataProcessingAgreement", "nda", "leaseAgreement", "purchaseAgreement" ;
  rdfs:label "Contract Type Vocabulary Constraint"@en .

dcst:constraint-contract-party-role a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "supplier", "customer", "provider", "client" ;
  rdfs:label "Contract Party Role Vocabulary Constraint"@en .

dcst:constraint-gdpr-role a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "controller", "processor", "jointController", "subProcessor" ;
  rdfs:label "GDPR Role Vocabulary Constraint"@en .

dcst:constraint-dispute-method a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "court", "arbitration", "mediation" ;
  rdfs:label "Dispute Resolution Method Vocabulary Constraint"@en .

dcst:constraint-audit-frequency a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "onDemand", "annual", "semiAnnual", "quarterly" ;
  rdfs:label "Audit Frequency Vocabulary Constraint"@en .

dcst:constraint-governing-law a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "DE", "AT", "CH", "FR", "NL", "BE", "EU" ;
  rdfs:label "Governing Law Vocabulary Constraint"@en .

dcst:constraint-ip-ownership a dcs:ValueConstraint ;
  dcs:format "controlled-vocabulary" ;
  dcs:allowedValue "customer", "supplier", "joint", "preExistingRetained" ;
  rdfs:label "IP Ownership Vocabulary Constraint"@en .

dcst:field-company-legalName a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Legal Name"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-registrationNumber a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Registration Number"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-vatId a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company VAT ID"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-representative-name a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Representative Name"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-representative-role a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Representative Role"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-contact-email a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Contact Email"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-contact-phone a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Contact Phone"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-location-street a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Street"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-location-postalCode a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Postal Code"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-location-city a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company City"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-location-region a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Region"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string .

dcst:field-company-location-country a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Company Country"@en ;
  rdfs:domain dcs:CompanyParty ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-iso3166-alpha3-country .

dcst:field-contract-type a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Contract Type"@en ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-contract-type .

dcst:field-contract-title a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Contract Title"@en ;
  rdfs:range xsd:string .

dcst:field-contract-jurisdiction a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Contract Jurisdiction"@en ;
  rdfs:domain dcs:LegalTerms ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-iso3166-alpha3-country .

dcst:field-contract-governingLaw a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Governing Law"@en ;
  rdfs:domain dcs:LegalTerms ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-governing-law .

dcst:field-contract-disputeResolution-venue a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Dispute Venue"@en ;
  rdfs:domain dcs:LegalTerms ;
  rdfs:range xsd:string .

dcst:field-contract-validity-startDate a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Validity Start Date"@en ;
  rdfs:range xsd:date .

dcst:field-contract-validity-endDate a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Validity End Date"@en ;
  rdfs:range xsd:date .

dcst:field-contract-effectiveDate a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Effective Date"@en ;
  rdfs:range xsd:date .

dcst:field-contract-renewal-noticePeriodDays a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Renewal Notice Period"@en ;
  rdfs:range xsd:integer .

dcst:field-contract-termination-noticePeriodDays a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Termination Notice Period"@en ;
  rdfs:range xsd:integer .

dcst:field-contract-payment-amount a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Payment Amount"@en ;
  rdfs:domain dcs:PaymentTerm ;
  rdfs:range xsd:decimal .

dcst:field-contract-payment-currency a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Payment Currency"@en ;
  rdfs:domain dcs:PaymentTerm ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-iso4217-currency .

dcst:field-contract-payment-dueDate a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Payment Due Date"@en ;
  rdfs:domain dcs:PaymentTerm ;
  rdfs:range xsd:date .

dcst:field-contract-payment-dueDays a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Payment Due Days"@en ;
  rdfs:domain dcs:PaymentTerm ;
  rdfs:range xsd:integer .

dcst:field-contract-liability-capAmount a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Liability Cap Amount"@en ;
  rdfs:range xsd:decimal .

dcst:field-contract-liability-currency a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Liability Currency"@en ;
  rdfs:range xsd:string .

dcst:field-contract-insurance-minimumCoverage a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Minimum Insurance Coverage"@en ;
  rdfs:range xsd:decimal .

dcst:field-contract-confidentiality-durationMonths a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Confidentiality Duration"@en ;
  rdfs:range xsd:integer .

dcst:field-contract-dataProtection-role a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Data Protection Role"@en ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-gdpr-role .

dcst:field-contract-disputeResolution-method a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Dispute Resolution Method"@en ;
  rdfs:domain dcs:LegalTerms ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-dispute-method .

dcst:field-contract-auditRights-frequency a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Audit Rights Frequency"@en ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-audit-frequency .

dcst:field-contract-ipRights-ownership a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "IP Rights Ownership"@en ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-ip-ownership .

dcst:field-contract-forceMajeure-noticeDays a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Force Majeure Notice Days"@en ;
  rdfs:range xsd:integer .

dcst:field-service-description a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Service Description"@en ;
  rdfs:range xsd:string .

dcst:field-service-scope a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Service Scope"@en ;
  rdfs:range xsd:string .

dcst:field-service-deliverable-name a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Deliverable Name"@en ;
  rdfs:range xsd:string .

dcst:field-service-deliverable-acceptanceCriteria a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Acceptance Criteria"@en ;
  rdfs:range xsd:string .

dcst:field-service-sla-availability a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "SLA Availability"@en ;
  rdfs:domain dcs:SLO ;
  rdfs:range xsd:decimal ;
  dcs:hasValueConstraint dcst:constraint-sla-availability-percent .

dcst:field-service-sla-responseTime a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "SLA Response Time"@en ;
  rdfs:domain dcs:SLO ;
  rdfs:range xsd:integer ;
  dcs:hasValueConstraint dcst:constraint-duration-minutes-non-negative .

dcst:field-service-sla-resolutionTime a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "SLA Resolution Time"@en ;
  rdfs:domain dcs:SLO ;
  rdfs:range xsd:integer ;
  dcs:hasValueConstraint dcst:constraint-duration-minutes-non-negative .

dcst:field-service-sla-supportHours a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Support Hours"@en ;
  rdfs:domain dcs:SLO ;
  rdfs:range xsd:string .

dcst:field-signature-requiredLevel a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Required Signature Level"@en ;
  rdfs:domain dcs:SignatureRequirement ;
  rdfs:range xsd:string ;
  dcs:hasValueConstraint dcst:constraint-eidas-signature-level .

dcst:field-signature-requiredSignerRole a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Required Signer Role"@en ;
  rdfs:domain dcs:SignatureRequirement ;
  rdfs:range xsd:string .

dcst:field-signature-deadline a dcs:DomainField, owl:DatatypeProperty ;
  rdfs:label "Signature Deadline"@en ;
  rdfs:domain dcs:SignatureRequirement ;
  rdfs:range xsd:date .
