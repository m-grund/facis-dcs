@prefix dcs: <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix dcst: <https://w3id.org/facis/dcs/taxonomy/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# The FACIS SLA domain-field catalog: the dcs:DomainField properties the
# template builder offers for placeholder and ODRL-constraint binding, with
# their value constraints and taxonomy value options. Served versioned by
# the Semantic Hub as name="facis-sla" kind="ontology"; the field IRIs are
# the identities documents reference via dcs:domainField.

<https://w3id.org/facis/sla/ontology> a owl:Ontology ;
  rdfs:label "FACIS SLA Domain Fields"@en ;
  rdfs:comment "Domain-field catalog for SLA contracting in FACIS DCS: field properties (rdfs:domain names the entity the field describes, rdfs:range its datatype), value constraints, and value-option taxonomies."@en ;
  rdfs:seeAlso <https://w3id.org/facis/dcs/ontology/v1> .

dcs:SLO a rdfs:Class ;
  rdfs:label "Service Level Objective"@en .

dcs:CompanyParty a rdfs:Class ;
  rdfs:label "Company Party"@en ;
  rdfs:comment "A company acting as a contract party. Its dcs:role identifies its function in the current contract."@en .

dcs:DomainField a owl:Class ;
  rdfs:subClassOf rdf:Property ;
  rdfs:label "Domain Field"@en ;
  skos:definition "A contract-data field templates may bind placeholders and ODRL constraints to; its IRI is its identity."@en .

dcs:ContractPartyRoleCode a rdfs:Class ;
  rdfs:subClassOf dcs:VocabularyTerm ;
  rdfs:label "Contract Party Role Code"@en .

dcs:PaymentTerm a rdfs:Class ;
  rdfs:label "Payment Term"@en .

dcs:LegalTerms a rdfs:Class ;
  rdfs:label "Legal Terms"@en .

dcs:SignatureRequirement a rdfs:Class ;
  rdfs:label "Signature Requirement"@en .

dcs:party a rdf:Property ;
  rdfs:label "Company Party"@en ;
  rdfs:comment "A company acting as a party to the contract."@en ;
  dcs:documentProperty "parties" ;
  rdfs:range dcs:CompanyParty .

dcs:role a rdf:Property ;
  rdfs:label "Role"@en ;
  rdfs:comment "Contract-scoped function of a party, for example supplier or customer."@en ;
  rdfs:range dcs:ContractPartyRoleCode ;
  dcs:hasValueConstraint dcst:constraint-contract-party-role .

dcst:constraint-iso3166-alpha3-country a dcs:ValueConstraint ;
  dcs:valueType dcs:CountryReference ;
  dcs:format "iso-3166-1-alpha-3" ;
  dcs:pattern "^[A-Z]{3}$" ;
  dcs:allowedValuesRef "ISO 3166-1 alpha-3" ;
  dcs:valueCatalog dcst:catalog-iso3166-alpha3-country ;
  dcs:allowedValue "DEU", "AUT", "CHE", "FRA", "NLD", "BEL", "LUX", "POL", "CZE", "ESP", "ITA", "GBR", "USA", "DNK", "SWE", "NOR", "FIN", "IRL", "PRT", "GRC", "CAN", "JPN", "AUS" ;
  rdfs:label "ISO 3166-1 alpha-3 Country Constraint"@en .

dcst:constraint-iso4217-currency a dcs:ValueConstraint ;
  dcs:valueType dcs:CurrencyReference ;
  dcs:format "iso-4217" ;
  dcs:pattern "^[A-Z]{3}$" ;
  dcs:allowedValuesRef "ISO 4217" ;
  dcs:valueCatalog dcst:catalog-iso4217-currency ;
  dcs:allowedValue "EUR", "USD", "GBP", "CHF", "PLN", "CZK" ;
  rdfs:label "ISO 4217 Currency Constraint"@en .

dcst:country-DEU a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "DEU" ;
  skos:prefLabel "Germany"@en .

dcst:country-AUT a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "AUT" ;
  skos:prefLabel "Austria"@en .

