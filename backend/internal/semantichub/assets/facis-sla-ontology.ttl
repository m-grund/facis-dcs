dcst:currency-EUR a skos:Concept ;
  skos:inScheme dcst:catalog-iso4217-currency ;
  skos:notation "EUR" ;
  skos:prefLabel "Euro"@en ;
  dcs:valueSymbol "€" .

dcst:currency-USD a skos:Concept ;
  skos:inScheme dcst:catalog-iso4217-currency ;
  skos:notation "USD" ;
  skos:prefLabel "US Dollar"@en ;
  dcs:valueSymbol "$" .

dcst:currency-GBP a skos:Concept ;
  skos:inScheme dcst:catalog-iso4217-currency ;
