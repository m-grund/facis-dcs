  skos:notation "POL" ;
  skos:prefLabel "Poland"@en .

dcst:country-CZE a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "CZE" ;
  skos:prefLabel "Czechia"@en .

dcst:country-ESP a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "ESP" ;
  skos:prefLabel "Spain"@en .

dcst:country-ITA a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "ITA" ;
  skos:prefLabel "Italy"@en .

dcst:country-GBR a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "GBR" ;
  skos:prefLabel "United Kingdom"@en .

dcst:country-USA a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "USA" ;
  skos:prefLabel "United States"@en .

dcst:country-DNK a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "DNK" ;
  skos:prefLabel "Denmark"@en .

dcst:country-SWE a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "SWE" ;
  skos:prefLabel "Sweden"@en .

dcst:country-NOR a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "NOR" ;
  skos:prefLabel "Norway"@en .

dcst:country-FIN a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "FIN" ;
  skos:prefLabel "Finland"@en .

dcst:country-IRL a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "IRL" ;
  skos:prefLabel "Ireland"@en .

dcst:country-PRT a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "PRT" ;
  skos:prefLabel "Portugal"@en .

dcst:country-GRC a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "GRC" ;
  skos:prefLabel "Greece"@en .

dcst:country-CAN a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "CAN" ;
  skos:prefLabel "Canada"@en .

dcst:country-JPN a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "JPN" ;
