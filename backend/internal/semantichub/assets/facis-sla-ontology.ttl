  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "CHE" ;
  skos:prefLabel "Switzerland"@en .

dcst:country-FRA a skos:Concept ;
  skos:inScheme dcst:catalog-iso3166-alpha3-country ;
  skos:notation "FRA" ;
  skos:prefLabel "France"@en .

