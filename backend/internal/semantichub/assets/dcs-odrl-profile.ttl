@prefix dcs:  <https://w3id.org/facis/dcs/ontology/v1#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# The DCS ODRL profile: the vocabulary extensions a FACIS DCS document's
# odrl:profile declaration commits its policies to. Every produced
# template carries one enclosing odrl:Offer, every contract instance one
# odrl:Agreement; rules live under odrl:permission / odrl:prohibition /
# odrl:obligation and each carries exactly one odrl:action plus
# odrl:assigner, odrl:assignee, and odrl:target.

<https://w3id.org/facis/dcs/ontology/v1/odrl-profile>
  a owl:Ontology, odrl:Profile ;
  rdfs:label "FACIS DCS ODRL Profile" ;
  dcterms:description """ODRL 2.2 profile for FACIS Digital Contracting
Service policies. Constraint left operands are dcs:RequirementField
instances declared in the same document's dcs:contractData. A constraint
governs the submitted value whose dcs:semanticConditionValues entry
references the constraint's odrl:leftOperand via dcs:forField. Reported
KPI metrics bind to constraints by dcs:parameterName equality between the
metric name and the left-operand field.""" ;
  dcs:defaultConstraintAction dcs:provideCompliantValue ;
  owl:imports <http://www.w3.org/ns/odrl/2/> .

dcs:defaultConstraintAction
  a owl:AnnotationProperty ;
  rdfs:label "default constraint action" ;
  skos:definition "The odrl:action a document producer attaches to field-value constraint rules generated under this profile." .

dcs:appliesToParameterType
  a owl:AnnotationProperty ;
  rdfs:label "applies to parameter type" ;
  skos:definition "The dcs:RequirementField parameter types (string, decimal, integer, boolean, date, enum) whose value constraints may use this operator." .

dcs:provideCompliantValue
  a odrl:Action ;
  rdfs:label "provide compliant value" ;
  skos:definition "The assignee provides a value for the constraint's left-operand field that satisfies the declared constraint." ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> ;
  odrl:includedIn odrl:use .

# A dcs:RequirementField referenced as odrl:leftOperand is a left operand:
# its runtime value is the dcs:semanticConditionValues entry whose
# dcs:forField references it.
dcs:RequirementField rdfs:subClassOf odrl:LeftOperand .

# The constraint operators this profile supports, with the parameter types
# each applies to. Declaration order is the order operator choices are
# offered in per parameter type. odrl:isAnyOf / odrl:isNoneOf take a set of
# right operands and are offered only for fields with an enumerable value
# constraint.

odrl:gt
  a odrl:Operator ;
  rdfs:label "Must be greater than" ;
  dcs:appliesToParameterType "decimal", "integer", "date" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:gteq
  a odrl:Operator ;
  rdfs:label "Must be at least" ;
  dcs:appliesToParameterType "decimal", "integer", "date" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:lt
  a odrl:Operator ;
  rdfs:label "Must be less than" ;
  dcs:appliesToParameterType "decimal", "integer", "date" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:lteq
  a odrl:Operator ;
  rdfs:label "Must be at most" ;
  dcs:appliesToParameterType "decimal", "integer", "date" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:eq
  a odrl:Operator ;
  rdfs:label "Must equal" ;
  dcs:appliesToParameterType "string", "decimal", "integer", "boolean", "date", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:neq
  a odrl:Operator ;
  rdfs:label "Must not equal" ;
  dcs:appliesToParameterType "string", "decimal", "integer", "boolean", "date", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:hasPart
  a odrl:Operator ;
  rdfs:label "Must contain" ;
  dcs:appliesToParameterType "string", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

dcs:matchesRegex
  a odrl:Operator ;
  rdfs:label "Must match pattern" ;
  skos:definition "The left-operand value matches the right-operand regular expression." ;
  dcs:appliesToParameterType "string", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:isAnyOf
  a odrl:Operator ;
  rdfs:label "Allow only" ;
  dcs:appliesToParameterType "string", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .

odrl:isNoneOf
  a odrl:Operator ;
  rdfs:label "Exclude" ;
  dcs:appliesToParameterType "string", "enum" ;
  skos:inScheme <https://w3id.org/facis/dcs/ontology/v1/odrl-profile> .
