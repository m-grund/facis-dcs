@prefix facisv: <https://w3id.org/facis/dcs/validation/v1#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

facisv:SLABasicProfile a facisv:ValidationProfile ;
  facisv:profileId "facis.sla.basic.v1" ;
  facisv:version "1" ;
  rdfs:comment "Basic FACIS SLA contract statement validation profile." .

facisv:ExactlyOneProviderShape a sh:NodeShape ;
  facisv:profile facisv:SLABasicProfile ;
  facisv:ruleId "exactly-one-provider" ;
  facisv:ruleType "count" ;
  sh:severity sh:Violation ;
  sh:message "Contract requires exactly one provider." ;
  facisv:where "@type=dcs:CompanyParty" ;
  facisv:where "role=dcst:role-provider" ;
  facisv:operator "eq" ;
  facisv:value 1 .

facisv:ExactlyOneCustomerShape a sh:NodeShape ;
  facisv:profile facisv:SLABasicProfile ;
  facisv:ruleId "exactly-one-customer" ;
  facisv:ruleType "count" ;
  sh:severity sh:Violation ;
  sh:message "Contract requires exactly one customer." ;
  facisv:where "@type=dcs:CompanyParty" ;
  facisv:where "role=dcst:role-customer" ;
  facisv:operator "eq" ;
  facisv:value 1 .

facisv:AvailabilitySLORequiredShape a sh:NodeShape ;
  facisv:profile facisv:SLABasicProfile ;
  facisv:ruleId "availability-slo-required" ;
  facisv:ruleType "required_fields" ;
  sh:severity sh:Violation ;
  sh:message "Availability SLO is incomplete." ;
  facisv:where "@type=dcs:ServiceLevelObjective" ;
  facisv:requiredField "availability" .

facisv:PaymentRequiredShape a sh:NodeShape ;
  facisv:profile facisv:SLABasicProfile ;
  facisv:ruleId "payment-required" ;
  facisv:ruleType "required_fields" ;
  sh:severity sh:Violation ;
  sh:message "Payment term is incomplete." ;
  facisv:where "@type=dcs:PaymentTerm" ;
  facisv:requiredField "amount" ;
  facisv:requiredField "currency" ;
  facisv:requiredField "dueDate" .

facisv:PaymentAmountPositiveShape a sh:NodeShape ;
  facisv:profile facisv:SLABasicProfile ;
  facisv:ruleId "payment-amount-positive" ;
  facisv:ruleType "comparison" ;
  sh:severity sh:Violation ;
  sh:message "Payment amount must be greater than 0." ;
  facisv:where "@type=dcs:PaymentTerm" ;
  facisv:target "amount" ;
  facisv:operator "gt" ;
  facisv:value 0 .
