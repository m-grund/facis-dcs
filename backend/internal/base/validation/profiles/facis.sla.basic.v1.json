{
  "id": "facis.sla.basic.v1",
  "version": "1",
  "description": "Basic FACIS SLA contract statement validation profile.",
  "rules": [
    {
      "id": "exactly-one-provider",
      "type": "count",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#Party",
        "role": "https://w3id.org/facis/dcs/taxonomy/v1#role-provider"
      },
      "operator": "eq",
      "value": 1,
      "message": "Contract requires exactly one provider."
    },
    {
      "id": "exactly-one-customer",
      "type": "count",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#Party",
        "role": "https://w3id.org/facis/dcs/taxonomy/v1#role-customer"
      },
      "operator": "eq",
      "value": 2,
      "message": "Contract requires exactly one customer."
    },
    {
      "id": "availability-slo-required",
      "type": "required_fields",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#ServiceLevelObjective",
        "metric": "https://w3id.org/facis/dcs/ontology/v1#Availability"
      },
      "requiredFields": ["value"],
      "message": "Availability SLO is incomplete."
    },
    {
      "id": "payment-party-references-exist",
      "type": "references",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#PaymentTerm"
      },
      "referenceFields": [
        {
          "field": "payer",
          "where": {
            "@type": "https://w3id.org/facis/dcs/ontology/v1#Party"
          }
        },
        {
          "field": "payee",
          "where": {
            "@type": "https://w3id.org/facis/dcs/ontology/v1#Party"
          }
        }
      ],
      "message": "Payment term references unknown parties."
    },
    {
      "id": "payment-amount-positive",
      "type": "comparison",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#PaymentTerm"
      },
      "target": "amount",
      "operator": "gt",
      "value": 0,
      "message": "Payment amount must be greater than 0."
    },
    {
      "id": "obligation-target-references-exist",
      "type": "references",
      "severity": "error",
      "where": {
        "@type": "https://w3id.org/facis/dcs/ontology/v1#Obligation"
      },
      "referenceFields": [
        {
          "field": "target"
        }
      ],
      "message": "Obligation references an unknown target statement."
    }
  ]
}
