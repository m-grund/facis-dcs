 {
  "id": "validate",
  "type": "function",
  "z": "tsa_flow",
  "name": "Validate + Build OpenSSL",
  "func": "const hash = msg.req.params.hash;\n\nif (!/^[a-fA-F0-9]{64}$/.test(hash)) {\n    msg.statusCode = 400;\n    msg.payload = \"Invalid SHA-256 hash\";\n    return [null, msg];\n}\n\nmsg.hash = hash;\nmsg.tsqfile = `/tmp/request-${msg._msgid}.tsq`;\nmsg.tsrfile = `/tmp/request-${msg._msgid}.tsr`;\nmsg.payload = `ts -query -digest ${hash} -sha256 -cert -out ${msg.tsqfile}`;\n\nreturn [msg, null];",
  "outputs": 2,
  "timeout": "",
  "noerr": 0,
  "initialize": "",
  "finalize": "",
  "libs": [],
  "x": 400,
  "y": 300,
  "wires": [
   [
    "exec"
   ],
   [
    "http_resp_error"
   ]
  ]
 },
 {
  "id": "exec",
  "type": "exec",
  "z": "tsa_flow",
  "command": "openssl",
  "addpay": "payload",
  "append": "",
  "useSpawn": "false",
  "timer": "",
  "winHide": false,
