 {
  "id": "check_rc",
  "type": "function",
  "z": "tsa_flow",
  "name": "Check reply rc",
  "func": "if (msg.payload && msg.payload.code === 0) {\n    msg.filename = msg.tsrfile;\n    return [msg, null];\n}\nmsg.statusCode = 502;\nmsg.payload = `local TSA reply failed rc=${msg.payload && msg.payload.code}`;\nreturn [null, msg];",
