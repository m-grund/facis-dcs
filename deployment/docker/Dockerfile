#-- Frontend Build Stage --
FROM node:22-alpine AS frontend-builder

WORKDIR /frontend

# Copy frontend package files
COPY frontend/ClientApp/package*.json ./
COPY frontend/ClientApp/package-lock.json ./

# Install frontend dependencies
RUN npm ci

# Copy frontend source
COPY frontend/ClientApp/ ./
COPY docs/semantic-ontology/ /docs/semantic-ontology/
COPY docs/ontology/ /docs/ontology/

# Build frontend (type-checking skipped — use build:docker to avoid blocking on TS errors)
RUN npm run build:docker


#-- Go Build Stage --
# glibc (Debian) toolchain with cgo: the PKCS#11 layer (ThalesGroup/crypto11 →
# miekg/pkcs11) is cgo-only, so a static CGO_ENABLED=0 build cannot link it.
FROM golang:1.25 AS go-builder

WORKDIR /build

# Copy go mod files
COPY backend/go.mod backend/go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY backend/ ./

# Generate Goa transport/types from the design package.
RUN go run goa.design/goa/v3/cmd/goa@v3.24.2 gen digital-contracting-service/design

# Build binary (cgo enabled so the PKCS#11 signing path links).
RUN CGO_ENABLED=1 GOOS=linux go build -o dcs ./cmd/dcs


#-- Runtime Stage --
FROM debian:stable-slim

ARG DOCKER_USER=default_user

ENV DEBIAN_FRONTEND=noninteractive

# softhsm2 provides libsofthsm2.so (the PKCS#11 module the backend dlopens) and
# softhsm2-util. opensc provides pkcs11-tool, openssl issues the dev x5chain,
# curl+jq let the provisioning job write the x5chain into a Kubernetes Secret.
# SoftHSM2 is a software token for dev/staging/CI only, never a production HSM.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    wget \
    gnupg \
    softhsm2 \
    opensc \
    openssl \
    curl \
    jq && \
    rm -rf /var/lib/apt/lists/*

RUN groupadd -r "${DOCKER_USER}" && useradd -r -g "${DOCKER_USER}" "${DOCKER_USER}"

RUN mkdir -p /home/${DOCKER_USER}
RUN chmod 0777 /home/${DOCKER_USER}

RUN mkdir -p /app
RUN chown $DOCKER_USER:$DOCKER_USER /app

# Create directory for custom CA certificates
RUN mkdir -p /usr/local/share/ca-certificates/custom
RUN chmod 755 /usr/local/share/ca-certificates/custom

WORKDIR /app

USER $DOCKER_USER

# Copy compiled binary from go-builder stage
COPY --from=go-builder /build/dcs /app/dcs

# Copy OID4VP issuer trust for DCS.
COPY --from=go-builder --chown=$DOCKER_USER:$DOCKER_USER \
  /build/config/oid4vp/trust.dev.json /app/config/oid4vp/trust.dev.json

# Copy generated OpenAPI spec from go-builder stage
COPY --from=go-builder /build/gen/http/openapi3.json /app/gen/http/openapi3.json
COPY --chown=$DOCKER_USER:$DOCKER_USER docs/semantic-ontology/ /app/docs/semantic-ontology/
COPY --chown=$DOCKER_USER:$DOCKER_USER docs/ontology/ /app/docs/ontology/

# Copy built frontend from frontend-builder stage
COPY --from=frontend-builder --chown=$DOCKER_USER:$DOCKER_USER /frontend/dist /app/web/dist

# Copy frontend config injection script
COPY --chown=$DOCKER_USER:$DOCKER_USER frontend/ClientApp/inject-config.sh /app/web/
RUN chmod +x /app/web/inject-config.sh

# Copy SoftHSM2 token + x5chain provisioning scripts used by the Helm hook Job.
COPY --chown=$DOCKER_USER:$DOCKER_USER scripts/hsm-provision.sh scripts/c2pa-cert-provision.sh /app/scripts/
RUN chmod +x /app/scripts/hsm-provision.sh /app/scripts/c2pa-cert-provision.sh

# Copy entrypoint script
COPY --chown=$DOCKER_USER:$DOCKER_USER backend/docker-entrypoint.sh /app/
RUN chmod +x /app/docker-entrypoint.sh

# Environment variable declarations (no defaults - must be provided at runtime)
ENV DATABASE_URL=""
ENV NATS_URL=""
ENV HYDRA_PUBLIC_ISSUER_URL=""
ENV HYDRA_INTERNAL_ISSUER_URL=""
ENV HYDRA_CLIENT_ID=""
ENV HYDRA_CLIENT_SECRET=""
ENV HYDRA_REDIRECT_URI=""
ENV HYDRA_POST_LOGOUT_REDIRECT_URI=""
ENV HYDRA_ADMIN_URL=""
ENV FC_KEYCLOAK_REALM_URL=""
ENV FEDERATED_CATALOGUE_API_URL=""
ENV FEDERATED_CATALOGUE_CLIENT_ID=""
ENV FEDERATED_CATALOGUE_CLIENT_SECRET=""

# Frontend and Backend path configuration (production defaults)
ENV DCS_UI_PATH="/ui/"
ENV DCS_API_PATH="/"

EXPOSE 8991

ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["/app/dcs"]
